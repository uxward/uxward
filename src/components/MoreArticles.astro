---
import { essaysNewestFirst } from '../data/essays.js';
const { currentSlug } = Astro.props;
const moreArticles = essaysNewestFirst.filter(e => e.slug !== currentSlug).slice(0, 3);
---
<section class="container">
  <div class="more">
    <div class="grid">
      <div class="marker">§ ↗</div>
      <div>
        <div class="more-eyebrow">More from the writing</div>
        <div class="more-grid">
          {moreArticles.map(essay => (
            <a class="essay-card" href={`/writing/${essay.slug}`}>
              <div class="meta">Essay</div>
              <h3 class="title" set:html={essay.title} />
              <p class="deck">{essay.deck}</p>
            </a>
          ))}
        </div>
        <div class="all-link">
          <a href="/writing">All writing</a>
        </div>
      </div>
    </div>
  </div>
</section>
