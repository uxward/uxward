---
import Base from '../layouts/Base.astro';
import { slate } from '../data/slate.js';
import { essaysNewestFirst } from '../data/essays.js';
---
<Base title="uxward — Brandon E. B. Ward">
  <style>
    /* ---------- Block 01 — Fold ---------- */
    .fold {
      min-height: 88vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: var(--space-10) 0;
    }
    .fold .eyebrow-line {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-9);
    }
    .fold h1 {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: clamp(64px, 8.4vw, 116px);
      line-height: 0.94;
      letter-spacing: -0.035em;
      font-variation-settings: 'opsz' 144, 'SOFT' 30;
      color: var(--ink);
      margin: 0;
      max-width: 1080px;
    }
    .fold h1 em {
      font-style: italic;
      font-weight: 400;
      font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    }
    .fold .deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: 24px;
      line-height: 1.42;
      color: var(--body);
      margin: var(--space-8) 0 0;
      max-width: 720px;
      font-variation-settings: 'opsz' 36, 'SOFT' 80, 'WONK' 1;
    }
    .fold .meta {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-top: var(--space-9);
    }

    /* ---------- Section frame ---------- */
    section.block {
      padding: var(--space-10) 0;
      border-top: 1px solid var(--rule);
    }
    section.block.on-paper {
      background: var(--paper);
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
    }
    .eyebrow-section {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .section-head {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: 40px;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin: 0 0 var(--space-9) 0;
      font-variation-settings: 'opsz' 96, 'SOFT' 30;
      max-width: 720px;
    }
    .section-head em {
      font-style: italic;
      font-weight: 400;
      font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1;
    }

    /* ---------- Block 02 — Selected work ---------- */
    .work {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: var(--space-9);
      align-items: start;
    }
    .case {
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .case .num {
      font-family: var(--font-serif);
      font-feature-settings: "tnum" 1;
      font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
      font-weight: 300;
      font-size: 64px;
      line-height: 1;
      letter-spacing: -0.02em;
      color: var(--tertiary);
      display: block;
      margin-bottom: var(--space-6);
    }
    .case.hero .num { font-size: 84px; color: var(--ink); }
    .case .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--signature);
      margin-bottom: var(--space-5);
    }
    .case .badge::before {
      content: "";
      display: inline-block;
      width: 8px; height: 8px;
      background: var(--signature);
    }
    .case .title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 24px;
      line-height: 1.18;
      letter-spacing: -0.015em;
      color: var(--ink);
      font-variation-settings: 'opsz' 48, 'SOFT' 50;
      margin: 0 0 var(--space-3) 0;
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 4px;
      text-decoration-color: var(--rule);
    }
    .case.hero .title {
      font-size: 34px;
      line-height: 1.08;
      font-variation-settings: 'opsz' 96, 'SOFT' 50;
    }
    .case:hover .title { color: var(--signature); text-decoration-color: var(--signature); }
    .case .desc {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 400;
      font-size: 17px;
      line-height: 1.5;
      color: var(--body);
      margin: var(--space-3) 0 var(--space-5);
      max-width: 38ch;
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .case .meta {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
    }
    .see-all {
      margin-top: var(--space-10);
      display: inline-block;
      font-family: var(--font-serif);
      font-size: 18px;
      color: var(--ink);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 4px;
    }

    /* ---------- Block 03 — Currently building ---------- */
    .tools { border-top: 1px solid var(--rule); }
    .tool-row {
      display: grid;
      grid-template-columns: 220px 1fr 100px;
      gap: var(--space-7);
      align-items: baseline;
      padding: var(--space-6) 0;
      border-bottom: 1px solid var(--rule);
    }
    .tool-row .name {
      font-family: var(--font-serif);
      font-weight: 500;
      font-size: 22px;
      color: var(--ink);
      letter-spacing: -0.01em;
      font-variation-settings: 'opsz' 36, 'SOFT' 30;
    }
    .tool-row .desc {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 400;
      font-size: 17px;
      color: var(--body);
      line-height: 1.5;
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .tool-row .tag {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      text-align: right;
      text-decoration: none;
    }
    .tool-row a.tag { color: var(--ink); text-decoration: underline; text-underline-offset: 4px; text-decoration-thickness: 1px; }
    .tool-row a.tag:hover { color: var(--signature); }

    /* ---------- Block 04 — Recent writing ---------- */
    .essays {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: var(--space-9);
    }
    .essay {
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .essay .meta {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-5);
    }
    .essay .title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 23px;
      line-height: 1.2;
      letter-spacing: -0.015em;
      color: var(--ink);
      font-variation-settings: 'opsz' 48, 'SOFT' 50;
      margin: 0 0 var(--space-3) 0;
    }
    .essay .deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 400;
      font-size: 16.5px;
      line-height: 1.5;
      color: var(--body);
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .essay:hover .title { color: var(--signature); }

    /* ---------- Block 05 — Bio ---------- */
    .bio {
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      gap: var(--space-10);
      align-items: start;
    }
    .bio p {
      font-family: var(--font-serif);
      font-size: 19px;
      line-height: 1.65;
      color: var(--body);
      max-width: 580px;
      margin: 0 0 var(--space-7);
    }
    .bio .more {
      font-family: var(--font-serif);
      font-size: 17px;
      color: var(--ink);
      text-decoration: underline;
      text-underline-offset: 4px;
    }
    .portrait {
      border: 1px solid var(--rule);
      max-width: 360px;
    }
    .portrait img {
      display: block;
      width: 100%;
      height: auto;
    }

    /* ---------- Block 06 — Red bleed ---------- */
    .red-bleed {
      background: var(--signature);
      color: #FFFFFF;
      padding: 144px 0 132px;
      margin-top: var(--space-10);
    }
    .red-bleed .eyebrow-on-red {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.78);
      margin-bottom: var(--space-8);
    }
    .red-bleed h2 {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: clamp(48px, 6.4vw, 88px);
      line-height: 1.02;
      letter-spacing: -0.03em;
      color: #FFFFFF;
      font-variation-settings: 'opsz' 144, 'SOFT' 30;
      margin: 0;
      max-width: 980px;
    }
    .red-bleed h2 em {
      font-style: italic;
      font-weight: 400;
      font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    }
    .red-bleed .reach {
      margin-top: var(--space-9);
      display: flex;
      align-items: baseline;
      gap: var(--space-7);
      flex-wrap: wrap;
    }
    .red-bleed .reach a {
      color: #FFFFFF;
      font-family: var(--font-serif);
      font-size: 22px;
      display: inline-flex;
      align-items: center;
      gap: 0.5em;
    }
    .red-bleed .reach a .email-text {
      text-decoration: underline;
      text-underline-offset: 5px;
      text-decoration-thickness: 1px;
    }
    .red-bleed .reach a .send-ico { width: 0.82em; height: 0.82em; }
    .red-bleed .reach a:hover { color: rgba(255,255,255,0.78); }
    .red-bleed .reach a:hover .send-icon,
    .red-bleed .reach a:focus-visible .send-icon { animation: send-fly 0.5s ease; }
    .red-bleed .reach .kicker {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.78);
    }

    @media (max-width: 900px) {
      .work { grid-template-columns: 1fr; }
      .essays { grid-template-columns: 1fr; gap: var(--space-8); }
      .bio { grid-template-columns: 1fr; }
      .tool-row { grid-template-columns: 1fr 1fr; }
      .tool-row .tag { text-align: left; }
    }
    @media (max-width: 600px) {
      .tool-row { grid-template-columns: 1fr; }
    }
  </style>

  <!-- BLOCK 01 — Above the fold -->
  <section class="fold">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 01</div>
        <div>
          <div class="eyebrow-line">Brandon E. B. Ward — Senior design leadership</div>
          <h1>
            I've spent 25 years standing up design practice from scratch.
            Now I do it in the <em>AI&nbsp;era.</em>
          </h1>
          <p class="deck">
            I shipped <a href="/work/speakeazy" aria-label="Read the Speakeazy case study">Speakeazy</a> solo — live to real users since January 2026. Before that: 25 years standing up design practice at three startups, two agencies, and a decade at Precocity.
          </p>
          <div class="meta">— Currently considering senior design leadership · Dallas, TX —</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOCK 02 — Selected work -->
  <section class="block on-paper">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 02</div>
        <div>
          <div class="eyebrow-section">— Selected work —</div>
          <h2 class="section-head">Three pieces that <em>carry the slate.</em></h2>

          <div class="work">
            <a class="case hero" href="/work/speakeazy">
              <span class="badge">Hero of the slate</span>
              <span class="num">01</span>
              <h3 class="title">Speakeazy — the tool that should have existed</h3>
              <p class="desc">AI-native dialogue attribution and character analysis for audiobook narrators. Built solo; live to real users since January 2026. The load-bearing case on the site.</p>
              <span class="meta">2025–Present · Founder</span>
            </a>

            <a class="case" href="/work/precocity">
              <span class="num">02</span>
              <h3 class="title">Precocity — the ten-year build</h3>
              <p class="desc">First design hire; grew the practice over a decade from a two-person discipline into the team that ships against eight-figure enterprise contracts.</p>
              <span class="meta">2016–Present · Chief Experience Officer</span>
            </a>

            <a class="case" href="/work/autoco">
              <span class="num">03</span>
              <h3 class="title">a global automaker — testing like an outsider</h3>
              <p class="desc">Built and led the independent, bias-free usability practice — 17 studies, 3,500 hours of testing — that a global automaker eventually brought in-house.</p>
              <span class="meta">2017–2022 · Director of UX</span>
            </a>
          </div>

          <a class="see-all" href="/work">— See all {slate.length} selected pieces →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOCK 03 — Currently building -->
  <section class="block">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 03</div>
        <div>
          <div class="eyebrow-section">— Currently building —</div>
          <h2 class="section-head">Five tools, one builder, AI as the <em>medium.</em></h2>

          <div class="tools">
            <div class="tool-row">
              <div class="name">Speakeazy</div>
              <div class="desc">AI-native dialogue attribution and character analysis for voice actors. Real users.</div>
              <a class="tag" href="https://speakeazy.pro" target="_blank" rel="noopener">Live →</a>
            </div>
            <div class="tool-row">
              <div class="name">FORGE</div>
              <div class="desc">Context-to-complete-site-build via AI. The most ambitious tool of the set.</div>
              <a class="tag" href="https://github.com/brandonebward" target="_blank" rel="noopener">GitHub →</a>
            </div>
            <div class="tool-row">
              <div class="name">Verity</div>
              <div class="desc">Foundations of an enterprise UX research and reporting platform.</div>
              <span class="tag">Private</span>
            </div>
            <div class="tool-row">
              <div class="name">RAD</div>
              <div class="desc">Usability testing dashboard. Concrete designer-tooling artifact.</div>
              <a class="tag" href="https://github.com/brandonebward" target="_blank" rel="noopener">GitHub →</a>
            </div>
            <div class="tool-row">
              <div class="name">Markdown plugin</div>
              <div class="desc">In-house Figma-to-Markdown converter, used at Precocity for AI workflows.</div>
              <span class="tag">Internal</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOCK 04 — Recent writing -->
  <section class="block on-paper">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 04</div>
        <div>
          <div class="eyebrow-section">— Recent writing —</div>
          <h2 class="section-head">Quarterly. Long enough to be wrong <em>out loud.</em></h2>

          <div class="essays">
            {essaysNewestFirst.slice(0, 3).map((e) => (
              <a class="essay" href={`/writing/${e.slug}`}>
                <div class="meta">— {e.quarter} · Essay —</div>
                <h3 class="title" set:html={e.title} />
                <p class="deck">{e.deck}</p>
              </a>
            ))}
          </div>

          <a class="see-all" href="/writing">— All writing →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOCK 05 — Bio teaser -->
  <section class="block">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 05</div>
        <div>
          <div class="eyebrow-section">— About —</div>
          <div class="bio">
            <div>
              <p>
                I'm Brandon. I've spent 25 years building and running design practice — at three startups,
                two agencies, two senior consulting roles, and at Precocity for the last decade. I've
                shipped Speakeazy, FORGE, and a handful of smaller AI-era tools as their solo builder.
                I write here quarterly. I'm based in Dallas. I'm currently considering senior design
                leadership roles at companies that take design seriously.
              </p>
              <a class="more" href="/about">— More about me →</a>
            </div>
            <div class="portrait">
              <img src="/images/BrandonEBWard-002.jpg"
                   alt="Portrait of Brandon E. B. Ward"
                   width="1200" height="1799" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOCK 06 — The earned red moment -->
  <section class="red-bleed">
    <div class="container">
      <div class="grid">
        <div class="marker" style="color: rgba(255,255,255,0.78);">§ 06</div>
        <div>
          <div class="eyebrow-on-red">— Currently considering —</div>
          <h2>
            Senior design leadership at companies that take design <em>seriously.</em>
          </h2>
          <div class="reach">
            <a href="mailto:brandon@uxward.com">
              <svg class="send-ico" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><g class="send-icon"><path d="M10 14l11 -11" /><path d="M21 3l-6.5 18a.55 .55 0 0 1 -1 0l-3.5 -7l-7 -3.5a.55 .55 0 0 1 0 -1l18 -6.5" /></g></svg>
              <span class="email-text">brandon@uxward.com</span>
            </a>
            <span class="kicker">— Direct line, read daily —</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
