---
import Base from '../layouts/Base.astro';
---
<Base title="About — Brandon E. B. Ward · uxward">
  <style>
    .about-top { padding-top: var(--space-8); padding-bottom: var(--space-7); }
    .about-top a.back {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      text-decoration: none;
    }
    .about-top a.back:hover { color: var(--signature); }

    .name-block { padding-top: var(--space-9); padding-bottom: var(--space-10); }
    .name-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-7);
    }
    h1.name {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: clamp(56px, 7vw, 104px);
      line-height: 0.96;
      letter-spacing: -0.035em;
      font-variation-settings: 'opsz' 144, 'SOFT' 30;
      color: var(--ink);
      margin: 0;
      max-width: 1080px;
    }
    h1.name em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    }
    .name-deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: 24px;
      line-height: 1.42;
      color: var(--body);
      margin: var(--space-8) 0 0;
      max-width: 720px;
      font-variation-settings: 'opsz' 36, 'SOFT' 80, 'WONK' 1;
    }

    .portrait-section {
      padding: var(--space-8) 0 var(--space-10);
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      background: var(--paper);
    }
    .portrait-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
      align-items: end;
      padding-top: var(--space-9);
    }
    .portrait {
      border: 1px solid var(--rule);
      max-width: 480px;
      width: 100%;
      margin-left: auto;
    }
    .portrait img {
      display: block;
      width: 100%;
      height: auto;
    }
    .portrait-caption {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 17px;
      line-height: 1.5;
      color: var(--body);
      max-width: 380px;
      margin: 0;
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
      padding-bottom: var(--space-6);
    }
    .portrait-caption .source {
      display: block;
      margin-top: var(--space-4);
      font-style: normal;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
    }

    .bio-section { padding: var(--space-10) 0; }
    .bio-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .bio-prose p {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 19px;
      line-height: 1.65;
      color: var(--body);
      max-width: 660px;
      margin: 0 0 var(--space-6);
      text-wrap: pretty;
    }
    .bio-prose p strong { font-weight: 500; color: var(--ink); }
    .bio-prose ul {
      font-family: var(--font-serif);
      font-size: 19px;
      line-height: 1.65;
      color: var(--body);
      max-width: 660px;
      margin: 0 0 var(--space-6);
      padding-left: 1.4em;
    }
    .bio-prose li { margin-bottom: var(--space-3); }

    .timeline-section {
      padding: var(--space-10) 0;
      border-top: 1px solid var(--rule);
    }
    .timeline-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .timeline-head {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: 40px;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin: 0 0 var(--space-9) 0;
      font-variation-settings: 'opsz' 96, 'SOFT' 30;
      max-width: 720px;
    }
    .timeline-head em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1;
    }
    .tl { border-top: 1px solid var(--rule); }
    .tl-row {
      display: grid;
      grid-template-columns: 160px 1fr 200px;
      gap: var(--space-7);
      padding: var(--space-5) 0;
      border-bottom: 1px solid var(--rule);
      align-items: baseline;
    }
    .tl-row .years {
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--tertiary);
    }
    .tl-row .role {
      font-family: var(--font-serif);
      font-size: 19px;
      line-height: 1.4;
      color: var(--ink);
      font-variation-settings: 'opsz' 24, 'SOFT' 30;
    }
    .tl-row .role em {
      font-style: italic;
      color: var(--body);
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .tl-row .place {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      text-align: right;
    }

    .currently-section {
      padding: var(--space-10) 0;
      border-top: 1px solid var(--rule);
    }
    .currently-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .currently-list {
      display: grid;
      gap: var(--space-6);
      max-width: 720px;
    }
    .currently-row {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: var(--space-7);
      padding-bottom: var(--space-5);
      border-bottom: 1px solid var(--rule);
      align-items: baseline;
    }
    .currently-row:last-child { border-bottom: 0; }
    .currently-row .key {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
    }
    .currently-row .vals {
      display: grid;
      gap: var(--space-4);
    }
    .currently-row .val {
      font-family: var(--font-serif);
      font-size: 20px;
      line-height: 1.45;
      color: var(--ink);
      font-variation-settings: 'opsz' 24, 'SOFT' 30;
    }
    .currently-row .val em {
      font-style: italic;
      color: var(--body);
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .currently-stamp {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-top: var(--space-7);
    }

    .elsewhere-section {
      padding: var(--space-10) 0;
      border-top: 1px solid var(--rule);
    }
    .elsewhere-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .elsewhere-list { border-top: 1px solid var(--rule); }
    .elsewhere-row {
      display: grid;
      grid-template-columns: 140px 1fr max-content;
      gap: var(--space-7);
      padding: var(--space-5) 0;
      border-bottom: 1px solid var(--rule);
      align-items: baseline;
    }
    .elsewhere-row .where {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
    }
    .elsewhere-row .what {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 17.5px;
      line-height: 1.5;
      color: var(--body);
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .elsewhere-row a.go {
      font-family: var(--font-serif);
      font-size: 17px;
      color: var(--ink);
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-thickness: 1px;
      text-align: right;
      white-space: nowrap;
    }
    .elsewhere-row a.go:hover { color: var(--signature); }

    @media (max-width: 900px) {
      .portrait-row { grid-template-columns: 1fr; }
      .tl-row { grid-template-columns: 1fr; }
      .tl-row .place { text-align: left; }
      .elsewhere-row { grid-template-columns: 1fr; }
      .elsewhere-row a.go { text-align: left; }
    }
  </style>

  <div class="container about-top">
    <div class="grid">
      <div class="marker">§ ↩</div>
      <div><a class="back" href="/">— Back home</a></div>
    </div>
  </div>

  <div class="container name-block">
    <div class="grid">
      <div class="marker">§ 00</div>
      <div>
        <div class="name-eyebrow">— About —</div>
        <h1 class="name">Brandon E. B. <em>Ward.</em></h1>
        <p class="name-deck">
          Executive design leader. Many years standing up design practices from scratch.
          Still in the tools, still shipping. Based in Dallas, working anywhere with a
          serious team.
        </p>
      </div>
    </div>
  </div>

  <section class="portrait-section">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 01</div>
        <div class="portrait-row">
          <div>
            <p class="portrait-caption">
              The page where the recruiter is compelled to read the long version.
              <span class="source">— B.E.B.W., Dallas, March 2026 —</span>
            </p>
          </div>
          <div class="portrait">
            <img src="/images/BrandonEBWard-006.jpg"
                 alt="Portrait of Brandon E. B. Ward"
                 width="1200" height="1712" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bio-section">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 02</div>
        <div>
          <div class="bio-eyebrow">— The longer version —</div>
          <div class="bio-prose">
            <p>
              I'm Brandon. I've spent my career building and running design practices
              — at four startups in the early 2000s, two design and digital agencies in the
              middle stretch, a senior consulting run after that, and at Precocity for
              the last decade. The throughline is that every one of those jobs began with the
              same sentence: <strong>there is no UX/SD/design practice yet; build one.</strong>
            </p>
            <p>
              The first startup was an e-learning organization I salvaged from dillution when the
              Director of Production abruptly quit, building the team, bringing everything in-house.
              The second was a small e-commerce platform where I learned to ship in a small room with
              engineers who outranked me and a CEO who wanted to sue me to stay when I left. The third
              was an early-to-market video search platform with all the promise and a scrupulous CEO. 
              The fourth taught me that products that lead with great design with the users in mind backed up by
              quality software is worth millions.
            </p>
            <p>
              The agency years were the years I learned to run a creative team. The
              consulting years after were the ones where I learned to run a creative team
              <strong>inside a business that didn't think of itself as a creative one.</strong>
              At Precocity I joined as the first UX hire and spent ten years growing the
              practice into the discipline that closes the firm's enterprise contracts. That
              case study is the load-bearing piece on this site. <a href="../work/precocity">Read it</a> if you read nothing
              else.
            </p>
            <p>
              During that run I was retained as the UX and user-research expert witness in
              <em>FTC v. Match.com</em> — the kind of work that only exists when the practice
              is taken seriously. Alongside the day job I co-founded the Dallas chapter of the
              Service Design Network — now roughly 5,000 members — and won the bid to host its
              2025 global conference.
            </p>
            <p>
              The AI-era expression of the same instinct, for me, has been shipping my own
              tools —
            </p>
            <ul>
              <li><a href="../work/speakeazy">Speakeazy</a> (live, real users)</li>
              <li>FORGE (a content-driven, AI-powered IA, UX, UI, and Build tool)</li>
              <li>Verity (a comprehensive UX Research platform)</li>
              <li>RAD (a visualization and reporting tool for moderated usability studies)</li>
              <li>Marksman (a MacOS Markdown converter mini-app Precocity uses internally for AI projects)</li>
              <li><a href="https://www.figma.com/community/plugin/1355255111922370746/design-library-showcase-generator-by-precocity">Design Library Showcase Generator</a> (a Figma plugin to help you instantly create a showcase of all library components and their variants)</li>
            </ul>
            <p>
              The tools matter to me less as products than as proof. I don't believe a design leader who
              hasn't shipped anything with their own hands in five years. Maybe it was a painting, or a teapot, or a chair, or an app. 
              The medium is different than it was in 2001. The discipline
              isn't.
            </p>
            <p>
              The summary version, for recruiters who scan: <strong>I build design practices
              from scratch, or take existing teams, turn them up to 11, and run them across every mode</strong> — strategy, creative
              direction, hands-on production. Unlike most leaders at my level, I'm still
              shipping in the new tools every week. I'm currently considering executive design
              leadership roles at companies that take design seriously.
            </p>
            <p>
              I live in Dallas. I write here periodically. I love kung fu, classic cars, singing, acting, teaching, traveling, husbanding, and fathering.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="timeline-section">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 03</div>
        <div>
          <div class="timeline-eyebrow">— Career, in years —</div>
          <h2 class="timeline-head">The years, told <em>plainly.</em></h2>

          <div class="tl">
            <div class="tl-row">
              <span class="years">2016 — Present</span>
              <span class="role">Chief Experience Officer — <em>built and grew the design practice over a decade.</em></span>
              <span class="place">Precocity · Dallas</span>
            </div>
            <div class="tl-row">
              <span class="years">2024 — Present</span>
              <span class="role">Founder, builder — <em>shipping Speakeazy, FORGE, and the AI-era toolchain.</em></span>
              <span class="place">Independent · Solo</span>
            </div>
            <div class="tl-row">
              <span class="years">2018 — Present</span>
              <span class="role">Co-founder &amp; host — <em>grew the Dallas chapter to ~5,000 members; hosted the 2025 global conference.</em></span>
              <span class="place">Service Design Network · Dallas</span>
            </div>
            <div class="tl-row">
              <span class="years">2013 — 2015</span>
              <span class="role">Senior experience designer — <em>UX and service design across client engagements.</em></span>
              <span class="place">Improving Enterprises</span>
            </div>
            <div class="tl-row">
              <span class="years">2013</span>
              <span class="role">Director of UX/UI — <em>stood up UX as a core practice; turned the studio digital.</em></span>
              <span class="place">StudioGood</span>
            </div>
            <div class="tl-row">
              <span class="years">2009 — 2013</span>
              <span class="role">Director of UX/UI &amp; lead developer — <em>the redesign behind a $35M acquisition.</em></span>
              <span class="place">TriGeo / SolarWinds</span>
            </div>
            <div class="tl-row">
              <span class="years">2008 — 2009</span>
              <span class="role">Senior designer &amp; developer — <em>design and build for a consumer sports platform.</em></span>
              <span class="place">Brainbox · Contract</span>
            </div>
            <div class="tl-row">
              <span class="years">2008</span>
              <span class="role">Director of UX/UI — <em>a video-search startup, later acquired by Limelight.</em></span>
              <span class="place">Delve Networks</span>
            </div>
            <div class="tl-row">
              <span class="years">2005 — 2007</span>
              <span class="role">UX/UI designer &amp; dev coordinator — <em>enterprise work for American Express and Microsoft.</em></span>
              <span class="place">MediaPro</span>
            </div>
            <div class="tl-row">
              <span class="years">2000 — 2004</span>
              <span class="role">Director of production — <em>UX/UI and multimedia for a design-tools startup.</em></span>
              <span class="place">Staffing Tools</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="currently-section">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 04</div>
        <div>
          <div class="currently-eyebrow">— Currently —</div>
          <div class="currently-list">
            <div class="currently-row">
              <span class="key">— Considering —</span>
              <span class="val">Executive design leadership at companies that take design seriously. <em>Head of Design, VP, CDO, CXO</em></span>
            </div>
            <div class="currently-row">
              <span class="key">— Building —</span>
              <div class="vals">
                <span class="val"><a href="../work/speakeazy">Speakeazy</a> — <em>Public, launched Jan. 1, 2026.</em></span>
                <span class="val">FORGE — Content > IA > Design > Code in minutes. <em>Private alpha, internal.</em></span>
                <span class="val">Verity — Comprehensive UXR platform that doesn't suck. <em>Private alpha, internal.</em></span>
              </div>
            </div>
            <div class="currently-row">
              <span class="key">— Reading —</span>
              <span class="val">Mostly LitRPG, Sci-Fi, and Fantasy, and the occasional business or design book. My <em>tsundoku</em> betrays me sometimes. I'll be the guy from <em>Time Enough At Last</em> screaming "There was time now. There was, was all the time I needed&hellip;"</span>
            </div>
            <div class="currently-row">
              <span class="key">— Not doing —</span>
              <span class="val">A newsletter. A podcast. A personal brand.</span>
            </div>
          </div>
          <div class="currently-stamp">— Updated quarterly · Last revised Q2 2026 —</div>
        </div>
      </div>
    </div>
  </section>

  <section class="elsewhere-section">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 05</div>
        <div>
          <div class="elsewhere-eyebrow">— Elsewhere —</div>
          <div class="elsewhere-list">
            <div class="elsewhere-row">
              <span class="where">— LinkedIn —</span>
              <span class="what">The professional record. The same ground, drier.</span>
              <a class="go" href="https://linkedin.com/in/brandonebward" target="_blank" rel="noopener">/in/brandonebward →</a>
            </div>
            <div class="elsewhere-row">
              <span class="where">— GitHub —</span>
              <span class="what">This site. Everything else is private.</span>
              <a class="go" href="https://github.com/uxward" target="_blank" rel="noopener">/uxward →</a>
            </div>
            <div class="elsewhere-row">
              <span class="where">— Acting —</span>
              <span class="what">The other thing I do. A different address; deliberately separated.</span>
              <a class="go" href="https://brandonebward.com" target="_blank" rel="noopener">brandonebward.com →</a>
            </div>
            <div class="elsewhere-row">
              <span class="where">— Email —</span>
              <span class="what">The direct line. Read daily. The right way to reach me.</span>
              <a class="go" href="mailto:brandon@uxward.com">brandon@uxward.com →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
