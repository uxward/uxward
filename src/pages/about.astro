---
import Base from '../layouts/Base.astro';
---
<Base title="About — Brandon E. B. Ward · uxward">
  <style>
    .about-top { padding-top: var(--space-8); padding-bottom: var(--space-7); }
    .about-top a.back {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      text-decoration: none;
    }
    .about-top a.back:hover { color: var(--signature); }

    .name-block { padding-top: var(--space-9); padding-bottom: var(--space-10); }
    .name-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-7);
    }
    h1.name {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: clamp(56px, 7vw, 104px);
      line-height: 0.96;
      letter-spacing: -0.035em;
      font-variation-settings: 'opsz' 144, 'SOFT' 30;
      color: var(--ink);
      margin: 0;
      max-width: 1080px;
    }
    h1.name em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    }
    .name-deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: 24px;
      line-height: 1.42;
      color: var(--body);
      margin: var(--space-8) 0 0;
      max-width: 720px;
      font-variation-settings: 'opsz' 36, 'SOFT' 80, 'WONK' 1;
    }

    .portrait-section {
      padding: var(--space-8) 0 var(--space-10);
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      background: var(--paper);
    }
    .portrait-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
      align-items: end;
      padding-top: var(--space-9);
    }
    .portrait {
      border: 1px solid var(--rule);
      max-width: 480px;
      width: 100%;
      margin-left: auto;
    }
    .portrait img {
      display: block;
      width: 100%;
      height: auto;
    }
    .portrait-caption {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 17px;
      line-height: 1.5;
      color: var(--body);
      max-width: 380px;
      margin: 0;
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
      padding-bottom: var(--space-6);
    }
    .portrait-caption .source {
      display: block;
      margin-top: var(--space-4);
      font-style: normal;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
    }

    .bio-section { padding: var(--space-10) 0; }
    .bio-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .bio-prose p {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 19px;
      line-height: 1.65;
      color: var(--body);
      max-width: 660px;
      margin: 0 0 var(--space-6);
      text-wrap: pretty;
    }
    .bio-prose p strong { font-weight: 500; color: var(--ink); }

    .timeline-section {
      padding: var(--space-10) 0;
      border-top: 1px solid var(--rule);
    }
    .timeline-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .timeline-head {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: 40px;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin: 0 0 var(--space-9) 0;
      font-variation-settings: 'opsz' 96, 'SOFT' 30;
      max-width: 720px;
    }
    .timeline-head em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1;
    }
    .tl { border-top: 1px solid var(--rule); }
    .tl-row {
      display: grid;
      grid-template-columns: 160px 1fr 200px;
      gap: var(--space-7);
      padding: var(--space-5) 0;
      border-bottom: 1px solid var(--rule);
      align-items: baseline;
    }
    .tl-row .years {
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--tertiary);
    }
    .tl-row .role {
      font-family: var(--font-serif);
      font-size: 19px;
      line-height: 1.4;
      color: var(--ink);
      font-variation-settings: 'opsz' 24, 'SOFT' 30;
    }
    .tl-row .role em {
      font-style: italic;
      color: var(--body);
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .tl-row .place {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      text-align: right;
    }

    .currently-section {
      padding: var(--space-10) 0;
      border-top: 1px solid var(--rule);
    }
    .currently-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .currently-list {
      display: grid;
      gap: var(--space-6);
      max-width: 720px;
    }
    .currently-row {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: var(--space-7);
      padding-bottom: var(--space-5);
      border-bottom: 1px solid var(--rule);
      align-items: baseline;
    }
    .currently-row:last-child { border-bottom: 0; }
    .currently-row .key {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
    }
    .currently-row .val {
      font-family: var(--font-serif);
      font-size: 20px;
      line-height: 1.45;
      color: var(--ink);
      font-variation-settings: 'opsz' 24, 'SOFT' 30;
    }
    .currently-row .val em {
      font-style: italic;
      color: var(--body);
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .currently-stamp {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-top: var(--space-7);
    }

    .elsewhere-section {
      padding: var(--space-10) 0;
      border-top: 1px solid var(--rule);
    }
    .elsewhere-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .elsewhere-list { border-top: 1px solid var(--rule); }
    .elsewhere-row {
      display: grid;
      grid-template-columns: 200px 1fr 160px;
      gap: var(--space-7);
      padding: var(--space-5) 0;
      border-bottom: 1px solid var(--rule);
      align-items: baseline;
    }
    .elsewhere-row .where {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
    }
    .elsewhere-row .what {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 17.5px;
      line-height: 1.5;
      color: var(--body);
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .elsewhere-row a.go {
      font-family: var(--font-serif);
      font-size: 17px;
      color: var(--ink);
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-thickness: 1px;
      text-align: right;
    }
    .elsewhere-row a.go:hover { color: var(--signature); }

    @media (max-width: 900px) {
      .portrait-row { grid-template-columns: 1fr; }
      .tl-row { grid-template-columns: 1fr; }
      .tl-row .place { text-align: left; }
      .elsewhere-row { grid-template-columns: 1fr; }
      .elsewhere-row a.go { text-align: left; }
    }
  </style>

  <div class="container about-top">
    <div class="grid">
      <div class="marker">§ ↩</div>
      <div><a class="back" href="/">— Back home</a></div>
    </div>
  </div>

  <div class="container name-block">
    <div class="grid">
      <div class="marker">§ 00</div>
      <div>
        <div class="name-eyebrow">— About —</div>
        <h1 class="name">Brandon E. B. <em>Ward.</em></h1>
        <p class="name-deck">
          Senior design leader. Twenty-five years standing up design practice from scratch.
          Still in the tools, still shipping. Based in Dallas, working anywhere with a
          serious team.
        </p>
      </div>
    </div>
  </div>

  <section class="portrait-section">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 01</div>
        <div class="portrait-row">
          <div>
            <p class="portrait-caption">
              The page where the recruiter who's interested goes to read the long version.
              Everything below is more or less true. The numbers are.
              <span class="source">— B.W., Dallas, March 2026 —</span>
            </p>
          </div>
          <div class="portrait">
            <img src="/images/BrandonEBWard-006.jpg"
                 alt="Portrait of Brandon E. B. Ward"
                 width="1200" height="1712" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bio-section">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 02</div>
        <div>
          <div class="bio-eyebrow">— The longer version —</div>
          <div class="bio-prose">
            <p>
              I'm Brandon. I've spent twenty-five years building and running design practice
              — at three startups in the early 2000s, two design and digital agencies in the
              middle stretch, two senior consulting roles after that, and at Precocity for
              the last decade. The throughline is that every one of those jobs began with the
              same sentence: <strong>there is no design practice yet; build one.</strong>
            </p>
            <p>
              The first startup was an e-commerce platform that did not survive the second
              dot-com winter. I learned to ship in a small room with engineers who outranked
              me and a CEO who didn't know what a designer was for. The second startup taught
              me that good design dies first when a company runs out of money. The third
              taught me that the answer to that is to make the design work cheap to defend.
              I have been working from that lesson ever since.
            </p>
            <p>
              The agency years were the years I learned to run a creative team. The
              consulting years after were the ones where I learned to run a creative team
              <strong>inside a business that didn't think of itself as a creative one.</strong>
              At Precocity I joined as the first design hire and spent ten years growing the
              practice into the discipline that closes the firm's enterprise contracts. That
              case study is the load-bearing piece on this site. Read it if you read nothing
              else.
            </p>
            <p>
              The AI-era expression of the same instinct, for me, has been shipping my own
              tools — Speakeazy (live, real users), FORGE (the most ambitious of the set),
              Verity, RAD, a Markdown plugin Precocity uses internally. The tools matter to me
              less as products than as proof. I don't believe a senior design leader who
              hasn't shipped anything with their own hands in five years. So I keep shipping
              with my own hands. The medium is different than it was in 2001. The discipline
              isn't.
            </p>
            <p>
              The summary version, for recruiters who scan: <strong>I build design practice
              from scratch and run it across every mode</strong> — strategy, creative
              direction, hands-on production. Unlike most leaders at my level, I'm still
              shipping in the new tools every week. I'm currently considering senior design
              leadership roles at companies that take design seriously.
            </p>
            <p>
              I live in Dallas. I write here quarterly. I act, occasionally, at a different
              address. I am not on Twitter and I am not building a personal brand.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="timeline-section">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 03</div>
        <div>
          <div class="timeline-eyebrow">— Career, in years —</div>
          <h2 class="timeline-head">Twenty-five years, told <em>plainly.</em></h2>

          <div class="tl">
            <div class="tl-row">
              <span class="years">2016 — Present</span>
              <span class="role">Chief Experience Officer — <em>built and grew the design practice over a decade.</em></span>
              <span class="place">Precocity · Dallas</span>
            </div>
            <div class="tl-row">
              <span class="years">2024 — Present</span>
              <span class="role">Founder, builder — <em>shipping Speakeazy, FORGE, and the AI-era toolchain.</em></span>
              <span class="place">Independent · Solo</span>
            </div>
            <div class="tl-row">
              <span class="years">2013 — 2016</span>
              <span class="role">Director of UX — <em>stood up the in-house design team.</em></span>
              <span class="place">Match Marketing · Dallas</span>
            </div>
            <div class="tl-row">
              <span class="years">2010 — 2013</span>
              <span class="role">Senior consultant, UX — <em>enterprise engagements across financial services.</em></span>
              <span class="place">Slalom Consulting · Chicago</span>
            </div>
            <div class="tl-row">
              <span class="years">2007 — 2010</span>
              <span class="role">Creative director — <em>brand and product, twelve clients, zero stock photography.</em></span>
              <span class="place">Range Agency · Austin</span>
            </div>
            <div class="tl-row">
              <span class="years">2004 — 2007</span>
              <span class="role">Design lead — <em>shipped the first product. Survived the agency.</em></span>
              <span class="place">Threshold Digital · Austin</span>
            </div>
            <div class="tl-row">
              <span class="years">2002 — 2004</span>
              <span class="role">Designer #2 — <em>e-commerce, before e-commerce was a category.</em></span>
              <span class="place">Halfpipe Inc. · Boulder</span>
            </div>
            <div class="tl-row">
              <span class="years">2001 — 2002</span>
              <span class="role">Designer, founding team — <em>shipped, did not survive the winter.</em></span>
              <span class="place">Wirebound · Boulder</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="currently-section">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 04</div>
        <div>
          <div class="currently-eyebrow">— Currently —</div>
          <div class="currently-list">
            <div class="currently-row">
              <span class="key">— Considering —</span>
              <span class="val">Senior design leadership at companies that take design seriously. <em>Head of Design, VP, CDO.</em></span>
            </div>
            <div class="currently-row">
              <span class="key">— Building —</span>
              <span class="val">FORGE — the AI tool I'd most defend. <em>Public alpha, late 2026.</em></span>
            </div>
            <div class="currently-row">
              <span class="key">— Reading —</span>
              <span class="val">Annual reports, mostly. <em>The most honest design writing nobody calls design writing.</em></span>
            </div>
            <div class="currently-row">
              <span class="key">— Not doing —</span>
              <span class="val">A newsletter. A podcast. A personal brand. <em>The work is the brand.</em></span>
            </div>
          </div>
          <div class="currently-stamp">— Updated quarterly · Last revised Q1 2026 —</div>
        </div>
      </div>
    </div>
  </section>

  <section class="elsewhere-section">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 05</div>
        <div>
          <div class="elsewhere-eyebrow">— Elsewhere —</div>
          <div class="elsewhere-list">
            <div class="elsewhere-row">
              <span class="where">— LinkedIn —</span>
              <span class="what">The professional record. The same ground, drier.</span>
              <a class="go" href="https://linkedin.com/in/brandonebward" target="_blank" rel="noopener">linkedin.com/in/brandonebward →</a>
            </div>
            <div class="elsewhere-row">
              <span class="where">— GitHub —</span>
              <span class="what">FORGE, RAD, the Markdown plugin, a few smaller artifacts.</span>
              <a class="go" href="https://github.com/uxward" target="_blank" rel="noopener">github.com/uxward →</a>
            </div>
            <div class="elsewhere-row">
              <span class="where">— Acting —</span>
              <span class="what">The other thing I do. A different address; deliberately separated.</span>
              <a class="go" href="https://brandonebward.com" target="_blank" rel="noopener">brandonebward.com →</a>
            </div>
            <div class="elsewhere-row">
              <span class="where">— Email —</span>
              <span class="what">The direct line. Read daily. The right way to reach me.</span>
              <a class="go" href="mailto:brandon@uxward.com">brandon@uxward.com →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
