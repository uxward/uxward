---
import Base from '../../layouts/Base.astro';
import { slate } from '../../data/slate.js';

// Case number, prev/next, and counts derive from slate order — see src/data/slate.js.
const idx = slate.findIndex((c) => c.slug === 'precocity');
const self = slate[idx];
const num = String(idx + 1).padStart(2, '0');
const prev = slate[(idx + slate.length - 1) % slate.length];
const next = slate[(idx + 1) % slate.length];
---
<Base title="Precocity — the ten-year build · uxward" bodyClass="case">

  <style>
    /* — Proof-forward hero: lead with the practice, in numbers, not a placeholder
         image. Bespoke-in-page, matching the speakeazy/insurco convention. — */
    body.case .hero-proof {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-7);
      margin-top: var(--space-9);
      padding-top: var(--space-7);
      border-top: 1px solid var(--rule);
    }
    body.case .hero-proof .hp .label {
      font-family: var(--font-mono);
      font-size: 10.5px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-4);
    }
    body.case .hero-proof .hp .figure {
      font-family: var(--font-head);
      font-feature-settings: "tnum" 1;
      font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
      font-weight: 300;
      font-size: 64px;
      line-height: 1;
      letter-spacing: -0.025em;
      color: var(--ink);
      margin-bottom: var(--space-4);
    }
    body.case .hero-proof .hp .desc {
      font-family: var(--font-body);
      font-style: italic;
      font-size: 16px;
      line-height: 1.45;
      color: var(--body);
      max-width: 280px;
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    @media (max-width: 720px) {
      body.case .hero-proof { grid-template-columns: 1fr; gap: var(--space-6); }
    }
  </style>

  <div class="container breadcrumb">
    <div class="grid">
      <div class="marker">§ ↩</div>
      <div><a href="/work">— Back to all work</a></div>
    </div>
  </div>

  <div class="container title-block">
    <div class="grid">
      <div class="marker">§ 00</div>
      <div>
        <span class="case-num">{num}</span>
        <h1 class="case-title" set:html={self.title} />
        <p class="case-deck">
          I joined Precocity in 2016 as its first-ever UX hire — a
          discipline the firm had never had. Over the next ten years I built the practice, 
          made it the tip of the spear on every engagement, and grew from
          Director of UX to Chief Experience Officer and part-owner.
        </p>

        <div class="hero-proof">
          <div class="hp">
            <div class="label">— Tenure —</div>
            <div class="figure">10 yrs</div>
            <div class="desc">Director of UX → Chief Experience Officer, and part-owner.</div>
          </div>
          <div class="hp">
            <div class="label">— Reach —</div>
            <div class="figure">100+</div>
            <div class="desc">Clients served, across more than 120 engagements.</div>
          </div>
          <div class="hp">
            <div class="label">— Practice built —</div>
            <div class="figure">$4.4M</div>
            <div class="desc">Conservative UX/UI book of business, 2016 — 2026.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="meta-strip">
      <div class="grid">
        <div class="marker">§ ✻</div>
        <div class="meta-row">
          <div class="cell">
            <div class="label">Client</div>
            <div class="value">Precocity</div>
          </div>
          <div class="cell">
            <div class="label">Role</div>
            <div class="value">Director of UX → CXO</div>
          </div>
          <div class="cell">
            <div class="label">Timeframe</div>
            <div class="value">2016 — Present</div>
          </div>
          <div class="cell">
            <div class="label">Capacity</div>
            <div class="value">Built &amp; led the practice</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="cs">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 01</div>
        <div>
          <div class="cs-eyebrow"><span class="num">01</span>— Context —</div>
          <h2 class="cs-head">Five designers, and not one who started with the <em>user.</em></h2>
          <div class="cs-prose">
            <p>
              What drew me to Precocity in 2016 was the range. This was a digital consultancy
              that built on Microsoft Surface and large-format touch walls and tables before
              they were mainstream, shipped 3D in game engines like Unity, stood up B2B SaaS,
              built websites — and carried a marquee client in Deloitte. Technically and
              creatively, it was strong.
            </p>
            <p>
              What it didn't have was a user-experience practice. There were five talented UI,
              graphic, and brand designers, but no researcher, no UX methodology, and no one
              whose job was to start with the user and the problem rather than a handed-down
              list of requirements.
            </p>
            <p>
              I came in as the sixth person on the design team, and the first the firm had ever
              hired to do research and UX. The mandate was open-ended: <strong>stand up the
              discipline, however that needed to look.</strong> No practice to inherit, no
              playbook — the first months were spent designing the practice itself.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cs">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 02</div>
        <div>
          <div class="cs-eyebrow"><span class="num">02</span>— The problem, named clearly —</div>
          <h2 class="cs-head">Design arrived at the end of the line — after the real decisions were <em>already made.</em></h2>
          <div class="cs-prose">
            <p>
              The way work flowed, design was the last stop. Business analysts and developers
              gathered requirements, handed the design team a list, and asked for a UI. The
              designers made the screens look right — but no one had asked whether they solved
              the right problem, and no one had tested them with a real user.
            </p>
            <p>
              For a consultancy, that isn't only a craft problem; it's a business one. Clients
              were buying output instead of outcomes, and the firm carried the risk when a
              handsome, unvalidated screen didn't land in front of real people.
            </p>
            <blockquote class="cs-pullquote">
              Precocity could build almost anything. What it couldn't yet do was prove it was building the right thing.
            </blockquote>
            <p>
              The opportunity, stated plainly: <strong>make UX load-bearing — in the pitch and
              in delivery — so design led the engagement instead of decorating its tail end.</strong>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cs">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 03</div>
        <div>
          <div class="cs-eyebrow"><span class="num">03</span>— The approach —</div>
          <h2 class="cs-head">Lead with the user — and make UX the thing clients bought <em>first.</em></h2>
          <div class="cs-prose">
            <p>
              The first move was practical. Within the first weeks I moved the team off
              Balsamiq, Photoshop, and Illustrator onto Sketch — paired with the InVision they
              already used — not for novelty, but because the old toolchain couldn't support the
              way modern product design actually works.
            </p>
            <p>
              Then the practice itself. I wrote the methodology Precocity had never had:
              research first, problem first, data-driven. Start with the user, unravel the
              problem, build the information architecture, wireframe, rapidly prototype, test
              the wireframe before investing in high fidelity, test the high fidelity, then
              ship. I also brought service design — still new to the U.S. — into the firm's
              toolkit, a fresh way to serve a varied book of clients.
            </p>
            <p>
              To get UX into the room, I built a deck on the ROI of UX and carried it into pitch
              after pitch from 2016 until about 2022 — when the results had made the argument
              for me, and clients simply asked what the problem was, what it would cost, and how
              fast we could deliver. When the work demanded a research engine the firm didn't
              have, I built one: hiring and training contractors into researchers, run in two
              shifts so a deep testing week never meant twelve-hour days for any one person.
            </p>
          </div>

          <div class="choices">
            <div class="choice-row">
              <div class="key">— Chose to —</div>
              <div class="val">Start every engagement with the user and the problem — <strong>not a handed-down requirements list.</strong></div>
            </div>
            <div class="choice-row">
              <div class="key">— Chose to —</div>
              <div class="val">Sell the practice with an ROI-of-UX deck — until the outcomes made the deck unnecessary (~2022).</div>
            </div>
            <div class="choice-row">
              <div class="key">— Chose to —</div>
              <div class="val">Build a research engine from trained contractors in two shifts, rather than overhire ahead of the book.</div>
            </div>
            <div class="choice-row">
              <div class="key">— Chose to —</div>
              <div class="val">Put UX and UI in the room from day one. <strong>The tip of the spear, not the final coat of paint.</strong></div>
            </div>
            <div class="choice-row">
              <div class="key">— Chose <strong>not</strong> to —</div>
              <div class="val">Build a design system as a first act, or chase brand and marketing work. The firm's growth was in product.</div>
            </div>
            <div class="choice-row">
              <div class="key">— Chose to —</div>
              <div class="val">Drop low fidelity once rapid high-fi prototyping got faster — cutting a whole stage clients no longer had to fund.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cs">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 04</div>
        <div>
          <div class="cs-eyebrow"><span class="num">04</span>— The work itself —</div>
          <h2 class="cs-head">No single screen is the hero. The <em>practice</em> is.</h2>
          <div class="cs-prose" style="margin-bottom: var(--space-9);">
            <p>
              At a consultancy, the honest version of "the work" is that no one artifact carries
              it — the method is what compounds, engagement after engagement, from a global automaker to
              Porte to a major insurance broker and a hundred more. These three are the pieces of it I'd put on
              the table.
            </p>
          </div>

          <div class="artifacts">
            <div class="artifact">
              <div class="frame">
                <span class="placeholder-label">Artifact 01 / 03</span>
                <span class="placeholder-detail">
                  Selected slides from the ROI-of-UX pitch deck.
                </span>
              </div>
              <div class="caption-grid">
                <span class="num">01</span>
                <div class="body">
                  <h4>The ROI-of-UX deck</h4>
                  <p class="cap">
                    The deck I carried into pitch after pitch from 2016 to ~2022, arguing why
                    every engagement should lead with UX. It worked until it was obsolete — by
                    the end, clients didn't need convincing.
                  </p>
                </div>
              </div>
            </div>

            <div class="artifact">
              <div class="frame">
                <span class="placeholder-label">Artifact 02 / 03</span>
                <span class="placeholder-detail">
                  Redacted client journey map.
                </span>
              </div>
              <div class="caption-grid">
                <span class="num">02</span>
                <div class="body">
                  <h4>Journey maps &amp; personas</h4>
                  <p class="cap">
                    The front of the user-first method — the proof we'd understood the problem,
                    and the people it belonged to, before anyone drew a screen.
                  </p>
                </div>
              </div>
            </div>

            <div class="artifact">
              <div class="frame">
                <span class="placeholder-label">Artifact 03 / 03</span>
                <span class="placeholder-detail">
                  Redacted wireframes and high-fidelity screens.
                </span>
              </div>
              <div class="caption-grid">
                <span class="num">03</span>
                <div class="body">
                  <h4>Wireframe → tested → high fidelity</h4>
                  <p class="cap">
                    The pipeline itself: wireframes tested before high fidelity, high fidelity
                    tested before production. The same shape on engagement after engagement —
                    and the reason clients stopped paying to build the wrong thing.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cs outcomes-bleed">
    <div class="container">
      <div class="grid">
        <div class="marker" style="color: rgba(255,255,255,0.78);">§ 05</div>
        <div>
          <div class="cs-eyebrow"><span class="num">05</span>— Outcomes —</div>
          <h2 class="cs-head">
            Design went from the last stop to the tip of the spear — and <em>paid for itself many times over.</em>
          </h2>
          <div class="outcomes-stats">
            <div class="stat">
              <div class="label">— UX/UI book of business —</div>
              <div class="figure">$4.4M</div>
              <div class="desc">Conservative, 2016 — 2026. The practice I built, measured in dollars.</div>
            </div>
            <div class="stat">
              <div class="label">— Pitched · won —</div>
              <div class="figure">91%</div>
              <div class="desc">Win rate across 141 engagements I personally wrote and pitched.</div>
            </div>
            <div class="stat">
              <div class="label">— Referral · retention —</div>
              <div class="figure">~99%</div>
              <div class="desc">Client referral rate — and zero design-team layoffs in ten years.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cs">
    <div class="container">
      <div class="grid">
        <div class="marker">§ 06</div>
        <div>
          <div class="cs-eyebrow"><span class="num">06</span>— Reflection —</div>
          <h2 class="cs-head">What a decade of building actually <em>taught me.</em></h2>
          <div class="cs-prose">
            <p>
              The decade taught me the business, not just the craft. The move from Director of
              UX to Chief Experience Officer came with equity and an education in how a
              consultancy actually makes money — patiently taught by our chief creative officer,
              Tim Doll, and our COO, Tim Starling. For the first five years I was here we had no
              salespeople; the book grew on delivered work and relationships. And through
              2020 – 2025, while peers were retrenching, we grew every single year.
            </p>
            <p>
              The hardest lessons were about people. I learned to <strong>hire slow and fire
              fast</strong> the expensive way — by doing the opposite and watching everyone pay
              for it, the ones I held onto too long most of all. I learned to extend grace, to
              admit when I'm wrong, and to take a hard critique as a gift. And I learned what
              I'm proudest of: a design team no one ever had to lay off, where people used
              Precocity as a launchpad to senior research and design roles at the biggest names
              in the region — Southwest, Cigna, and more.
            </p>
            <p>
              What I carry forward is a bias I've had since I started out as a developer:
              <strong>build the version that survives a bad quarter, not the one you'd put on
              Dribbble.</strong> Being a coder first, I've always worked the seam between design
              and engineering — defending the user when the build is hard, and killing the
              over-wrought design when it isn't worth the cost. In the AI age I've started
              building again myself, sometimes live on a client call, turning what they're
              describing into something on screen before the meeting ends. The Speakeazy build
              is that same instinct with new tools. The medium keeps changing; the discipline
              doesn't.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="prevnext">
      <div class="pn-cell prev">
        <div class="label">— Previous case —</div>
        <a href={`/work/${prev.slug}`} set:html={`— ${prev.title}`} />
      </div>
      <div class="pn-cell next">
        <div class="label">— Next case —</div>
        <a href={`/work/${next.slug}`} set:html={`${next.title} —`} />
      </div>
    </div>

    <div class="back-all">
      <a href="/work">— Back to all {slate.length} selected pieces →</a>
    </div>
  </div>
</Base>
