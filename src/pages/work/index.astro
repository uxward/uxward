---
import Base from '../../layouts/Base.astro';
import { slate } from '../../data/slate.js';
import { essays } from '../../data/essays.js';

// — The selected slate — rendered from src/data/slate.js (single source of
// truth for order, numbering, and counts across the site).
const [hero, ...cases] = slate;

// — The wider archive — short cards for the fuller body of work.
// Heroes (Speakeazy, a global automaker, Porte, a major insurance broker, + Party City & Telescope to come)
// live in the slate above; Deloitte Intela is intentionally held out.
// Edit / reorder a card by editing one entry; the count below auto-updates.
// Optional: add `link: "…"` (read text) + `url: "https://…"` (href) to any
// still-live project and a link renders at the bottom of its card.
const archive = [
  { tag: "AR / sales",          client: "GarageVision",             hook: "seeing the door on your house",           out: "An AR app composites a custom garage door onto a customer's home in real time, with live pricing.", link: "view project", url: "https://www.garagevision.pro" },
  { tag: "Product strategy",    client: "Generational",             hook: "DealForce, the next-gen M&A platform",    out: "Business-model-canvas work defined the MVP and a roadmap for a best-in-class deal platform.", link: "view project", url: "https://www.dealforce.com" },
  { tag: "Navigation UX",       client: "Solovis",                  hook: "fixing the nav users got lost in",        out: "Tree-tested IA and usability-validated navigation lifted adoption and engagement.", link: "view project", url: "https://go.solovis.com/portfolio-analytics" },
  { tag: "Product design",      client: "Solovis",                  hook: "'what-if' modeling for asset managers",   out: "An app to stack unlimited scenarios with live-redrawing charts and a client presentation mode.", link: "view project", url: "https://go.solovis.com/predict"},
  { tag: "Strategy / UX",            client: "CollateralEdge",           hook: "research when they asked for a website",  out: "Insights and a journey map became the brand and site that pre-empted buyers' questions and doubts.", link: "view project", url: "https://collateraledge.com/"},
  { tag: "Web & UX",            client: "CDC Small Business Finance", hook: "a mission lender's site that converts", out: "A research-led, CTA-driven redesign lifted traffic, engagement, and conversions for an SMB lender.", link: "view project", url: "https://cdcloans.com/" },
  { tag: "Creative / games",    client: "American Heart Association", hook: "gamifying stroke awareness",            out: "Nog, an animated-brain game suite for F.A.S.T. — built in ~8 months, then extended to a Spanish R.A.P.I.D.O. edition.", link: "view project", url: "https://www.stroke.org/en/be-fast-experience" },
  { tag: "UX Legal Expert Witness",client: "Match",                 hook: "FTC vs. Match RE: Subscription cancelation",out: "Seven-hundred hours. Two-hundred usability studies. Over three-hundred pages in reports. A case fit for trial." },
  { tag: "Data & viz",          client: "Neiman Marcus",            hook: "Flashboard, real-time sales analytics",   out: "Consolidated siloed enterprise data into a responsive tool — drill-down to a single SKU at a single store." },
  { tag: "Product redesign",    client: "Crash Champions",          hook: "halving CSR call time",                   out: "The Hyperdrive redesign cut call time 50% — doubling call-center capacity — and ended mis-assigned vehicles." },
  { tag: "Design system",       client: "Deloitte",                 hook: "a dashboard platform in two weeks",       out: "Hi-fi prototype and a reusable style guide in 14 days — then the baseline for other Deloitte platforms." },
  { tag: "UX / UI",             client: "Deloitte",                 hook: "an acquired app, brought up to standard", out: "A ~4-week uplift aligned a newly-acquired product to brand and fixed its weakest flows." },
  { tag: "AR / MR",             client: "NOKIA",                    hook: "troubleshooting hardware through a HUD",  out: "A MS Hololens proof of concept identified faulty hardware in unfamiliar rooms and guided just-in-time repairs." },
  { tag: "AR",                  client: "NOKIA",                    hook: "just-in-time training for field techs",   out: "Mobile AR tutorials cut training and install time for contractors with little prior experience." },
  { tag: "VR",                  client: "RetailGIS",                hook: "walking a store before it's built",       out: "Turned existing 2D store schematics into multi-user VR walkthroughs in the Meta Quest." },
  { tag: "Usability research",  client: "a global automaker",                   hook: "an accident app for people in distress",  out: "A usability study surfaced dealbreaker limitations and the fixes to make it usable under stress." },
  { tag: "Usability research",  client: "Automaker Connected",         hook: "catching the flaw that left cars unlocked", out: "Real-world testing caught a return-flow defect that would've left every car unlocked after use." },
  { tag: "Usability research",  client: "a global automaker",                   hook: "programming a mirror, in a real car",     out: "In-vehicle testing of the full-display rearview mirror produced clearer controls, icons, and sunlight visibility." },
  { tag: "Adoption study",      client: "a global automaker",                   hook: "why a companion app wasn't catching on",  out: "A usability study pinpointed the onboarding and IA fixes to lift the companion app adoption." },
  { tag: "Accessibility",       client: "Automaker Mobility",          hook: "touchscreen controls for power wheelchairs", out: "Live-intercept surveys and two usability rounds (21 users) at the Dallas & LA Abilities Expos validated a touchscreen for Group 2–3 users." },
  { tag: "Enterprise UX",       client: "HKS",                      hook: "finding people across 24 offices",        out: "A PoC freed resourcing from a finance-only ERP, letting PMs find and plan talent worldwide." },
  { tag: "Enterprise platform", client: "Milestone",                hook: "paper onboarding, digitized",             out: "A bespoke portal automated onboarding and gave HR and execs real-time performance dashboards." },
  { tag: "Platform strategy",   client: "Success Group Int'l",      hook: "consolidating a fractured platform",      out: "A 6-week MVP definition and phased roadmap cut IT complexity and support costs." },
  { tag: "UX redesign",         client: "Success Group Int'l",      hook: "a sales scoreboard worth trusting",       out: "Redesign cut data-entry errors and maintenance costs, raising admin and subscriber satisfaction." },
  { tag: "Brand & 0→1",         client: "REdibs (now SellWhenever)", hook: "launching a novel real-estate model",    out: "Full brand, site, and portals plus a marketing strategy that improved agent conversion." },
  { tag: "Product design",      client: "FanPlan",                  hook: "a marketing concept made real",           out: "A 3-week discovery sprint defined personas, IA, and full customer + admin prototypes." },
  { tag: "CX / conversion",     client: "YPO",                      hook: "smoothing the path to membership",        out: "Hotjar and 1:1 research drove content and funnel fixes that sustained higher application rates." },
  { tag: "UX / engagement",     client: "YPO",                      hook: "a member portal worth returning to",      out: "Continuous-improvement UX work lifted engagement across a global member portal." },
  { tag: "Mobile",              client: "YPO",                      hook: "standardizing how leaders run forums",    out: "A native iOS/Android app for forum moderators, launched at the 2018 Global Leadership Conference." },
];
---
<Base title="Work · uxward">
  <style>
    .top { padding-top: var(--space-8); padding-bottom: var(--space-7); }
    .top a.back {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      text-decoration: none;
    }
    .top a.back:hover { color: var(--signature); }

    .page-title { padding-top: var(--space-9); padding-bottom: var(--space-9); }
    .page-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-7);
    }
    .page-h {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: clamp(48px, 6.4vw, 96px);
      line-height: 1.0;
      letter-spacing: -0.03em;
      font-variation-settings: 'opsz' 144, 'SOFT' 30;
      color: var(--ink);
      margin: 0;
    }
    .page-h em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    }
    .page-intro {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: 22px;
      line-height: 1.5;
      color: var(--body);
      max-width: 660px;
      margin: var(--space-7) 0 0;
      font-variation-settings: 'opsz' 36, 'SOFT' 80, 'WONK' 1;
    }

    .slate { padding-top: var(--space-7); padding-bottom: var(--space-9); }

    a.hero {
      display: block;
      text-decoration: none;
      color: inherit;
      padding: var(--space-9) 0 var(--space-10);
      border-top: 2px solid var(--ink);
      border-bottom: 1px solid var(--rule);
      transition: opacity var(--t-fast) ease;
    }
    a.hero .hero-head {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: var(--space-7);
      align-items: start;
    }
    a.hero .num {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: 96px;
      line-height: 0.9;
      letter-spacing: -0.03em;
      color: var(--signature);
      font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
      font-feature-settings: 'tnum' 1;
    }
    a.hero .num small {
      display: block;
      margin-top: var(--space-4);
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--signature);
      font-feature-settings: normal;
    }
    a.hero .hero-body { padding-top: 8px; }
    a.hero .hero-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--signature);
      margin-bottom: var(--space-6);
    }
    a.hero h2.hero-title {
      font-family: var(--font-head);
      font-weight: 300;
      font-size: clamp(40px, 5.4vw, 72px);
      line-height: 1.0;
      letter-spacing: -0.03em;
      color: var(--ink);
      font-variation-settings: 'opsz' 144, 'SOFT' 30;
      margin: 0;
      max-width: 880px;
      transition: color var(--t-fast) ease;
    }
    a.hero h2.hero-title em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    }
    a.hero .hero-deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: 22px;
      line-height: 1.45;
      color: var(--body);
      max-width: 660px;
      margin: var(--space-7) 0 0;
      font-variation-settings: 'opsz' 36, 'SOFT' 80, 'WONK' 1;
    }
    a.hero .hero-pullout {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: clamp(24px, 2.8vw, 32px);
      line-height: 1.25;
      color: var(--ink);
      border-left: 3px solid var(--signature);
      padding: 4px 0 4px var(--space-6);
      margin: var(--space-9) 0 0;
      max-width: 720px;
      font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1;
    }
    a.hero .hero-meta {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: baseline;
      gap: var(--space-7);
      margin-top: var(--space-9);
      padding-top: var(--space-6);
      border-top: 1px solid var(--rule);
    }
    a.hero .hero-meta .stamps {
      font-family: var(--font-mono);
      font-size: 11.5px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
    }
    a.hero .hero-meta .stamps span + span::before {
      content: " · ";
      color: var(--rule);
      padding: 0 8px;
    }
    a.hero .hero-meta .open {
      font-family: var(--font-serif);
      font-size: 18px;
      color: var(--ink);
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-thickness: 1px;
    }
    a.hero:hover h2.hero-title { color: var(--signature); }
    a.hero:hover .open { color: var(--signature); }

    a.case {
      display: block;
      text-decoration: none;
      color: inherit;
      padding: var(--space-8) 0;
      border-bottom: 1px solid var(--rule);
      transition: opacity var(--t-fast) ease;
    }
    a.case .row {
      display: grid;
      grid-template-columns: 200px 1fr 240px;
      gap: var(--space-7);
      align-items: start;
    }
    a.case .num {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: 56px;
      line-height: 0.9;
      letter-spacing: -0.025em;
      color: var(--tertiary);
      font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
      font-feature-settings: 'tnum' 1;
      padding-top: 6px;
    }
    a.case .body { padding-top: 4px; }
    a.case h3.case-title {
      font-family: var(--font-head);
      font-weight: 400;
      font-size: 34px;
      line-height: 1.08;
      letter-spacing: -0.018em;
      color: var(--ink);
      font-variation-settings: 'opsz' 96, 'SOFT' 30;
      margin: 0;
      max-width: 640px;
      transition: color var(--t-fast) ease;
    }
    a.case h3.case-title em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1;
    }
    a.case .case-deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 18px;
      line-height: 1.55;
      color: var(--body);
      max-width: 580px;
      margin: var(--space-5) 0 0;
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    a.case .meta {
      padding-top: 22px;
      text-align: right;
    }
    a.case .meta .stamps {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      line-height: 1.7;
    }
    a.case .meta .open {
      margin-top: var(--space-5);
      font-family: var(--font-serif);
      font-size: 17px;
      color: var(--ink);
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-thickness: 1px;
      display: inline-block;
    }
    a.case:hover h3.case-title { color: var(--signature); }
    a.case:hover .num { color: var(--signature); }
    a.case:hover .open { color: var(--signature); }

    .pivot {
      padding: var(--space-10) 0 var(--space-9);
      border-top: 1px solid var(--rule);
    }
    .pivot-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-7);
    }
    .pivot-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-9);
    }
    .pivot-card {
      text-decoration: none;
      color: inherit;
      display: block;
      padding-top: var(--space-5);
      border-top: 1px solid var(--rule);
    }
    .pivot-card .key {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-5);
    }
    .pivot-card .label {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: 32px;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--ink);
      font-variation-settings: 'opsz' 96, 'SOFT' 30;
    }
    .pivot-card .label em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1;
    }
    .pivot-card .why {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 17px;
      line-height: 1.5;
      color: var(--body);
      margin: var(--space-4) 0 0;
      max-width: 460px;
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .pivot-card:hover .label { color: var(--signature); }

    @media (max-width: 900px) {
      a.case .row { grid-template-columns: 80px 1fr; }
      a.case .meta { text-align: left; padding-top: var(--space-5); grid-column: 1 / -1; }
      a.hero .hero-head { grid-template-columns: 1fr; }
      a.hero .hero-meta { grid-template-columns: 1fr; }
      a.hero .hero-meta .stamps span { display: block; }
      a.hero .hero-meta .stamps span + span::before { display: none; }
      .pivot-grid { grid-template-columns: 1fr; }
      .arch-grid { grid-template-columns: 1fr 1fr; }
    }

    /* — The wider archive — */
    .archive {
      padding: var(--space-10) 0 var(--space-10);
      border-top: 2px solid var(--ink);
    }
    .arch-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-7);
    }
    .arch-h {
      font-family: var(--font-head);
      font-weight: 300;
      font-size: clamp(36px, 4.4vw, 56px);
      line-height: 1.02;
      letter-spacing: -0.025em;
      font-variation-settings: 'opsz' 144, 'SOFT' 30;
      color: var(--ink);
      margin: 0 0 var(--space-9);
    }
    .arch-h em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    }
    .arch-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8) var(--space-7);
    }
    .arch-card {
      border-top: 1px solid var(--rule);
      padding-top: var(--space-5);
    }
    .arch-card .tag {
      font-family: var(--font-mono);
      font-size: 10.5px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--signature);
      margin-bottom: var(--space-4);
    }
    .arch-card .arch-title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 21px;
      line-height: 1.2;
      letter-spacing: -0.012em;
      color: var(--ink);
      font-variation-settings: 'opsz' 36, 'SOFT' 30;
      margin: 0;
    }
    .arch-card .arch-title em {
      font-style: italic;
      font-variation-settings: 'opsz' 36, 'SOFT' 100, 'WONK' 1;
    }
    .arch-card .arch-out {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 15.5px;
      line-height: 1.5;
      color: var(--body);
      margin: var(--space-4) 0 0;
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .arch-card .arch-link {
      display: inline-block;
      margin-top: var(--space-4);
      font-family: var(--font-mono);
      font-size: 10.5px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--signature);
      text-decoration: none;
    }
    .arch-card .arch-link:hover { text-decoration: underline; }
    @media (max-width: 600px) {
      .arch-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="container top">
    <div class="grid">
      <div class="marker">§ ↩</div>
      <div><a class="back" href="/">— Back home</a></div>
    </div>
  </div>

  <div class="container page-title">
    <div class="grid">
      <div class="marker">§ 00</div>
      <div>
        <div class="page-eyebrow">— Work · The selected slate —</div>
        <h1 class="page-h">The work, <em>arranged by what it proves.</em></h1>
        <p class="page-intro">
          The curated set up top — the ones I most stand behind, arranged by what they
          prove, not when they shipped. The Speakeazy build is the load-bearing one.
          Below it, the wider archive: the fuller body of work, in brief.
        </p>
      </div>
    </div>
  </div>

  <section class="container slate">

    <a class="hero" href={`/work/${hero.slug}`} aria-label={`Open the ${hero.client} case study`}>
      <div class="hero-head">
        <div class="num">
          01
          <small>— Hero of the slate —</small>
        </div>
        <div class="hero-body">
          <div class="hero-eyebrow">— {hero.eyebrow} —</div>
          <h2 class="hero-title" set:html={hero.title} />
          <p class="hero-deck">{hero.deck}</p>
          <blockquote class="hero-pullout" set:html={hero.pullout} />
          <div class="hero-meta">
            <div class="stamps">
              {hero.stamps.map((s) => <span>— {s} —</span>)}
            </div>
            <span class="open">— Read the full case →</span>
          </div>
        </div>
      </div>
    </a>

    {cases.map((c, i) => (
      <a class="case" href={`/work/${c.slug}`}>
        <div class="row">
          <div class="num">{String(i + 2).padStart(2, '0')}</div>
          <div class="body">
            <h3 class="case-title" set:html={c.title} />
            <p class="case-deck">{c.deck}</p>
          </div>
          <div class="meta">
            <div class="stamps">
              {c.stamps.map((s) => <div>— {s} —</div>)}
            </div>
            <span class="open">— Open →</span>
          </div>
        </div>
      </a>
    ))}

  </section>

  <section class="container archive">
    <div class="grid">
      <div class="marker">§ ✦</div>
      <div>
        <div class="arch-eyebrow">— The wider archive · selected {archive.length} projects —</div>
        <h2 class="arch-h">The years, <em>in brief.</em></h2>
        <div class="arch-grid">
          {archive.map((c) => (
            <div class="arch-card">
              <div class="tag">— {c.tag} —</div>
              <h3 class="arch-title">{c.client} — <em>{c.hook}</em></h3>
              <p class="arch-out">{c.out}</p>
              {c.url && (
                <a class="arch-link" href={c.url} target="_blank" rel="noopener">{c.link} ↗</a>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="pivot">
      <div class="grid">
        <div class="marker">§ ↗</div>
        <div>
          <div class="pivot-eyebrow">— If the work isn't enough —</div>
          <div class="pivot-grid">
            <a class="pivot-card" href="/writing">
              <div class="key">— Writing —</div>
              <div class="label">Quarterly essays, <em>no newsletter.</em></div>
              <div class="why">Long-form notes on design leadership, restraint, and the AI-era discipline. {essays.length} pieces and counting.</div>
            </a>
            <a class="pivot-card" href="/about">
              <div class="key">— About —</div>
              <div class="label">The longer <em>recruiter-deep version.</em></div>
              <div class="why">Twenty-five years told plainly. The bio, the timeline, the things I'm currently considering.</div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>