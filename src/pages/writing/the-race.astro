---
import Base from '../../layouts/Base.astro';
---
<Base title="The Race · uxward">
  <style>
    .read-bar {
      position: fixed;
      top: 0; left: 0;
      height: 2px;
      width: 0%;
      background: var(--signature);
      z-index: 200;
      transition: width 80ms linear;
    }

    .reading-column {
      max-width: 660px;
      margin: 0 auto;
      padding: 0 var(--gutter-x);
    }

    .essay-top { padding: var(--space-8) 0 var(--space-7); }
    .essay-top .row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-7);
      flex-wrap: wrap;
    }
    .essay-top a.back,
    .essay-top .meta {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      text-decoration: none;
    }
    .essay-top a.back:hover { color: var(--ink); }
    .essay-top .meta .sep { padding: 0 12px; color: var(--rule); }

    .essay-title-block { padding: var(--space-9) 0 var(--space-10); }
    .essay-title {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: clamp(42px, 5.6vw, 76px);
      line-height: 1.02;
      letter-spacing: -0.025em;
      font-variation-settings: 'opsz' 144, 'SOFT' 30;
      color: var(--ink);
      margin: 0;
      max-width: 820px;
    }
    .essay-title em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    }
    .essay-deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: 22px;
      line-height: 1.45;
      color: var(--body);
      margin: var(--space-7) 0 0;
      max-width: 660px;
      font-variation-settings: 'opsz' 36, 'SOFT' 80, 'WONK' 1;
    }
    .essay-byline {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-top: var(--space-8);
    }

    .essay-body { padding: var(--space-9) 0 var(--space-10); }
    .essay-body p {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 18px;
      line-height: 1.65;
      color: var(--body);
      max-width: 660px;
      margin: 0 0 var(--space-6);
      font-variation-settings: 'opsz' 14;
      text-wrap: pretty;
    }
    .essay-body p strong { font-weight: 500; color: var(--ink); }
    .essay-body p em { font-style: italic; }
    .essay-body p:first-of-type::first-letter {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: 5.2em;
      line-height: 0.88;
      float: left;
      padding: 6px 12px 0 0;
      color: var(--ink);
      font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
    }
    .essay-body h2 {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 30px;
      line-height: 1.18;
      letter-spacing: -0.015em;
      color: var(--ink);
      margin: var(--space-10) 0 var(--space-7);
      font-variation-settings: 'opsz' 96, 'SOFT' 50;
      max-width: 660px;
    }
    .ornament {
      text-align: center;
      margin: var(--space-9) auto;
      font-family: var(--font-serif);
      font-size: 20px;
      color: var(--tertiary);
      letter-spacing: 0.6em;
      line-height: 1;
      user-select: none;
    }
    .poem {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 18px;
      line-height: 1.8;
      color: var(--body);
      max-width: 560px;
      margin: 0 0 var(--space-6);
      font-variation-settings: 'opsz' 14;
    }
    .poem-attribution {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-top: var(--space-8);
    }
    .essay-body figure { margin: var(--space-9) 0; }
    .essay-body figure img { max-width: 100%; height: auto; display: block; }
    .essay-body figure figcaption {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      color: var(--tertiary);
      margin-top: var(--space-4);
    }

    .essay-end {
      margin-top: var(--space-9);
      padding-top: var(--space-7);
      border-top: 1px solid var(--rule);
    }
    .essay-end .author {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-top: var(--space-6);
    }

    .more {
      border-top: 1px solid var(--rule);
      padding: var(--space-10) 0 var(--space-9);
    }
    .more .more-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .more-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: var(--space-9);
    }
    .more-grid .essay-card {
      text-decoration: none; color: inherit; display: block;
    }
    .more-grid .essay-card .meta {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-5);
    }
    .more-grid .essay-card .title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 22px;
      line-height: 1.22;
      letter-spacing: -0.015em;
      color: var(--ink);
      font-variation-settings: 'opsz' 48, 'SOFT' 50;
      margin: 0 0 var(--space-3);
    }
    .more-grid .essay-card .deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 16.5px;
      line-height: 1.5;
      color: var(--body);
      margin: 0;
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .more-grid .essay-card:hover .title { color: var(--tertiary); }

    .all-link { margin-top: var(--space-9); }
    .all-link a {
      font-family: var(--font-serif);
      font-size: 18px;
      color: var(--ink);
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-thickness: 1px;
    }

    @media (max-width: 720px) {
      .more-grid { grid-template-columns: 1fr; gap: var(--space-8); }
    }
  </style>

  <div class="read-bar" id="read-bar" aria-hidden="true"></div>

  <div class="reading-column essay-top">
    <div class="row">
      <a class="back" href="/writing">— Back to writing</a>
      <div class="meta">
        <span>Q2 2021</span>
        <span class="sep">·</span>
        <span>Poem</span>
        <span class="sep">·</span>
        <span>3 min read</span>
      </div>
    </div>
  </div>

  <div class="reading-column essay-title-block">
    <h1 class="essay-title">
      <em>The Race</em>
    </h1>
    <p class="essay-deck">
      A poem by Dr. D. H. Groberg, shared here because it matters.
    </p>
    <div class="essay-byline">— Shared by Brandon E. B. Ward —</div>
  </div>

  <article class="reading-column essay-body">

    <figure>
      <img src="/images/writing/the-race.jpg" alt="A runner on a track" />
    </figure>

    <p>
      "Quit! Give up! You're beaten!" they shout at me and plead.
      There's just too much against you now, this time you can't succeed.
      And as I start to hang my head in front of failure's face,
      My downward fall is broken by the memory of a race.
    </p>

    <div class="ornament">·  ·  ·</div>

    <p>
      And hope refills my weakened will as I recall that scene,
      For just the thought of that short race rejuvenates my being.
      A children's race, young boys, young men — how I remember well —
      Excitement sure, but also fear; it wasn't hard to tell.
    </p>

    <p>
      They all lined up so full of hope, each thought to win that race.
      Or tie for first, or if not that, at least take second place.
      Their fathers watched from off the side, each cheering for his son.
      And each boy hoped to show his dad that he would be the one.
    </p>

    <p>
      The whistle blew and off they flew like chariots of fire.
      There were ten boys in that race as each had his desire
      To run like the wind and win the race or, failing, do his best.
      To show his dad he had what it takes to somehow pass the test.
    </p>

    <div class="ornament">·  ·  ·</div>

    <p>
      Now one boy in particular, whose dad was in the crowd,
      Was running in the lead and thought "my dad will be so proud."
      But as he speeded down the field across a shallow dip,
      The little boy who thought to win lost his step and slipped.
    </p>

    <p>
      Trying hard to catch himself, his arms flew everywhere,
      And midst the laughter of the crowd, he fell flat on his face.
      As he fell, his hope fell too; he'd lost the race, he knew.
      "Get up," the boy said to himself. "You're not done yet — pursue!"
    </p>

    <p>
      With borrowed will, do it for dad, he rose up from the ground.
      But as he rose to run once more, the race was nearly done.
      The other runners had all passed him by — the shame, the pain!
      He neared the end with lowered head — to lose is not disgrace.
    </p>

    <div class="ornament">·  ·  ·</div>

    <p>
      "I've lost, so what?" he thought. "I'll smile, take joy in others' winning."
      But as he crossed the line in last, his dad cheered just the same.
      "My son," he said, "I'm proud of you. You rose. You ran. You came."
    </p>

    <p>
      And now when I'm tempted to quit and I feel the urge to run,
      I just borrow strength from that dad's words: "You rose. You ran. You came."
      Defeat? No. Not defeat at all. For winning's not the game.
      The race is run by human hearts — and that's the way it's played.
    </p>

    <div class="poem-attribution">— Dr. D. H. Groberg</div>

    <div class="essay-end">
      <div class="author">— Brandon E. B. Ward · Dallas, TX —</div>
    </div>

  </article>

  <section class="container">
    <div class="more">
      <div class="grid">
        <div class="marker">§ ↗</div>
        <div>
          <div class="more-eyebrow">— More from the writing —</div>
          <div class="more-grid">
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
          </div>
          <div class="all-link">
            <a href="/writing">— All writing →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function () {
      var bar = document.getElementById('read-bar');
      if (!bar) return;
      function update() {
        var doc = document.documentElement;
        var max = (doc.scrollHeight - doc.clientHeight);
        var pct = max > 0 ? Math.min(100, Math.max(0, (doc.scrollTop || window.scrollY) / max * 100)) : 0;
        bar.style.width = pct + '%';
      }
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
    })();
  </script>
</Base>
