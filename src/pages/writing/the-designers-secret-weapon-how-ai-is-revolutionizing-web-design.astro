---
import Base from '../../layouts/Base.astro';
---
<Base title="The Designer's Secret Weapon: How AI Is Revolutionizing Web Design · uxward">
  <style>
    .read-bar {
      position: fixed;
      top: 0; left: 0;
      height: 2px;
      width: 0%;
      background: var(--signature);
      z-index: 200;
      transition: width 80ms linear;
    }

    .reading-column {
      max-width: 660px;
      margin: 0 auto;
      padding: 0 var(--gutter-x);
    }

    .essay-top { padding: var(--space-8) 0 var(--space-7); }
    .essay-top .row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-7);
      flex-wrap: wrap;
    }
    .essay-top a.back,
    .essay-top .meta {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      text-decoration: none;
    }
    .essay-top a.back:hover { color: var(--ink); }
    .essay-top .meta .sep { padding: 0 12px; color: var(--rule); }

    .essay-title-block { padding: var(--space-9) 0 var(--space-10); }
    .essay-title {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: clamp(42px, 5.6vw, 76px);
      line-height: 1.02;
      letter-spacing: -0.025em;
      font-variation-settings: 'opsz' 144, 'SOFT' 30;
      color: var(--ink);
      margin: 0;
      max-width: 820px;
    }
    .essay-title em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    }
    .essay-deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: 22px;
      line-height: 1.45;
      color: var(--body);
      margin: var(--space-7) 0 0;
      max-width: 660px;
      font-variation-settings: 'opsz' 36, 'SOFT' 80, 'WONK' 1;
    }
    .essay-byline {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-top: var(--space-8);
    }

    .essay-body { padding: var(--space-9) 0 var(--space-10); }
    .essay-body p {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 18px;
      line-height: 1.65;
      color: var(--body);
      max-width: 660px;
      margin: 0 0 var(--space-6);
      font-variation-settings: 'opsz' 14;
      text-wrap: pretty;
    }
    .essay-body p strong { font-weight: 500; color: var(--ink); }
    .essay-body p em { font-style: italic; }
    .essay-body p:first-of-type::first-letter {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: 5.2em;
      line-height: 0.88;
      float: left;
      padding: 6px 12px 0 0;
      color: var(--ink);
      font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
    }
    .essay-body h2 {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 30px;
      line-height: 1.18;
      letter-spacing: -0.015em;
      color: var(--ink);
      margin: var(--space-10) 0 var(--space-7);
      font-variation-settings: 'opsz' 96, 'SOFT' 50;
      max-width: 660px;
    }
    .essay-body h2 em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1;
    }
    .essay-body blockquote {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: 26px;
      line-height: 1.35;
      color: var(--ink);
      border-left: 3px solid var(--signature);
      padding: 4px 0 4px var(--space-7);
      margin: var(--space-9) 0;
      max-width: 600px;
      font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1;
    }
    .essay-body figure { margin: var(--space-9) 0; }
    .essay-body figure img { max-width: 100%; height: auto; display: block; }
    .essay-body figure figcaption {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      color: var(--tertiary);
      margin-top: var(--space-4);
    }

    .essay-end {
      margin-top: var(--space-9);
      padding-top: var(--space-7);
      border-top: 1px solid var(--rule);
    }
    .essay-end .author {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-top: var(--space-6);
    }

    .more {
      border-top: 1px solid var(--rule);
      padding: var(--space-10) 0 var(--space-9);
    }
    .more .more-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .more-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: var(--space-9);
    }
    .more-grid .essay-card {
      text-decoration: none; color: inherit; display: block;
    }
    .more-grid .essay-card .meta {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-5);
    }
    .more-grid .essay-card .title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 22px;
      line-height: 1.22;
      letter-spacing: -0.015em;
      color: var(--ink);
      font-variation-settings: 'opsz' 48, 'SOFT' 50;
      margin: 0 0 var(--space-3);
    }
    .more-grid .essay-card .deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 16.5px;
      line-height: 1.5;
      color: var(--body);
      margin: 0;
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .more-grid .essay-card:hover .title { color: var(--tertiary); }

    .all-link { margin-top: var(--space-9); }
    .all-link a {
      font-family: var(--font-serif);
      font-size: 18px;
      color: var(--ink);
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-thickness: 1px;
    }

    @media (max-width: 720px) {
      .more-grid { grid-template-columns: 1fr; gap: var(--space-8); }
    }
  </style>

  <div class="read-bar" id="read-bar" aria-hidden="true"></div>

  <div class="reading-column essay-top">
    <div class="row">
      <a class="back" href="/writing">— Back to writing</a>
      <div class="meta">
        <span>Q1 2023</span>
        <span class="sep">·</span>
        <span>Essay</span>
        <span class="sep">·</span>
        <span>8 min read</span>
      </div>
    </div>
  </div>

  <div class="reading-column essay-title-block">
    <h1 class="essay-title">
      The Designer's <em>Secret Weapon:</em> How AI Is Revolutionizing Web Design
    </h1>
    <p class="essay-deck">
      Machine learning tools are not replacing designers. They are giving designers leverage they have never had before — if designers are willing to use them.
    </p>
    <div class="essay-byline">— By Brandon E. B. Ward —</div>
  </div>

  <article class="reading-column essay-body">

    <figure>
      <img src="/images/writing/ai-design-abstract.jpg" alt="AI and design — abstract illustration" />
    </figure>

    <p>
      The conversation about AI in design has been happening at two extremes. On one side: AI will replace designers, the profession is ending, start learning to code. On the other: AI is just a gimmick, real design requires human judgment, the hype will pass. Both positions are wrong. The more interesting question is the one neither side is asking: what can a designer do with these tools that they could not do before?
    </p>

    <h2>What AI is actually good at</h2>

    <figure>
      <img src="/images/writing/Screenshot+2023-01-17+at+4.38.51+PM.png" alt="AI design tool interface screenshot" />
    </figure>

    <p>
      Current AI design tools are good at a specific set of things. They are good at generating large volumes of visual options quickly. They are good at translating natural language descriptions into starting-point compositions. They are good at producing variations on an existing theme. They are good at filling in the tedious parts of a design workflow — generating placeholder imagery, writing microcopy alternatives, suggesting color palette variations.
    </p>

    <p>
      They are not good at strategy. They are not good at understanding organizational constraints or political context. They are not good at navigating the specific, messy, human dynamics of a stakeholder review. They do not know what your users actually need. They cannot replace the judgment formed by years of watching users struggle with interfaces.
    </p>

    <p>
      The designer who uses AI tools to handle the mechanical parts of the job — and redirects that time toward judgment, strategy, and research — is more valuable than a designer who does either alone.
    </p>

    <h2>Accessibility as a use case</h2>

    <figure>
      <img src="/images/writing/blind-reading.jpg" alt="Person using a screen reader" />
    </figure>

    <p>
      One of the most underutilized applications of AI in design is accessibility. Automated accessibility scanning has existed for years, but it catches a narrow slice of issues — contrast ratios, missing alt text, structural markup. The harder accessibility problems — cognitive load, task complexity, error recovery, screen reader experience — require human testing.
    </p>

    <p>
      Emerging AI tools are beginning to close that gap. Natural language processing tools that can describe an interface in the terms a screen reader user would encounter. Vision models that can simulate how an interface appears to someone with various types of color blindness or low vision. These are not replacements for testing with real users who have disabilities — but they are vastly better than nothing, and they surface issues much earlier in the process.
    </p>

    <h2>Personalization at scale</h2>

    <figure>
      <img src="/images/writing/mobile-stock-app.png" alt="Mobile app with personalized content" />
    </figure>

    <p>
      Personalization has been a design goal for decades and an engineering problem for just as long. Designing for one user is tractable. Designing for a thousand user segments is not — or was not. Machine learning models that can adapt interfaces to individual usage patterns, surface relevant content at the right moment, and adjust information density to match user expertise change that equation.
    </p>

    <p>
      The design implication is significant. When personalization is possible at scale, the designer's job shifts. You are no longer designing a single experience. You are designing a system of experiences, and the parameters of that system, and the guardrails that ensure every variation meets a quality bar. That is a harder and more interesting design problem than "design the homepage."
    </p>

    <figure>
      <img src="/images/writing/landing-page-toggledWords.png" alt="Landing page with AI-toggled word variants for personalization" />
    </figure>

    <h2>The leverage point</h2>

    <p>
      The designers who will thrive in an AI-augmented industry are not the ones who are best at using the tools. They are the ones who understand the limits of the tools well enough to know when not to use them — and who have developed judgment, empathy, and strategic thinking that no tool can replicate.
    </p>

    <blockquote>
      AI gives designers leverage. Judgment determines what to do with it.
    </blockquote>

    <p>
      The secret weapon is not the AI. It is the designer who uses the AI wisely — who understands what it can and cannot do, who applies it to the right problems, and who maintains the human perspective at the center of every decision.
    </p>

    <div class="essay-end">
      <div class="author">— Brandon E. B. Ward · Dallas, TX —</div>
    </div>

  </article>

  <section class="container">
    <div class="more">
      <div class="grid">
        <div class="marker">§ ↗</div>
        <div>
          <div class="more-eyebrow">— More from the writing —</div>
          <div class="more-grid">
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
          </div>
          <div class="all-link">
            <a href="/writing">— All writing →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function () {
      var bar = document.getElementById('read-bar');
      if (!bar) return;
      function update() {
        var doc = document.documentElement;
        var max = (doc.scrollHeight - doc.clientHeight);
        var pct = max > 0 ? Math.min(100, Math.max(0, (doc.scrollTop || window.scrollY) / max * 100)) : 0;
        bar.style.width = pct + '%';
      }
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
    })();
  </script>
</Base>
