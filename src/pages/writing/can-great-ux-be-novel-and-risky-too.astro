<Base title="Can Great UX Be Novel and Risky Too? · uxward" bodyClass="essay">
  <div class="read-bar" id="read-bar" aria-hidden="true"></div>

  <div class="reading-column essay-top">
    <div class="row">
      <a class="back" href="/writing">Back to writing</a>
      <div class="meta">
        <span>Q3 2021</span>
        <span class="sep">·</span>
        <span>Essay</span>
        <span class="sep">·</span>
        <span>5 min read</span>
      </div>
    </div>
