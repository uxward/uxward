---
import Base from '../../layouts/Base.astro';
---
<Base title="The Triforce of UX: Part I — Empathy · uxward">
  <style>
    .read-bar { position: fixed; top: 0; left: 0; height: 2px; width: 0%; background: var(--signature); z-index: 200; transition: width 80ms linear; }
    .reading-column { max-width: 660px; margin: 0 auto; padding: 0 var(--gutter-x); }
    .essay-top { padding: var(--space-8) 0 var(--space-7); }
    .essay-top .row { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-7); flex-wrap: wrap; }
    .essay-top a.back, .essay-top .meta { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--tertiary); text-decoration: none; }
    .essay-top a.back:hover { color: var(--ink); }
    .essay-top .meta .sep { padding: 0 12px; color: var(--rule); }
    .essay-title-block { padding: var(--space-9) 0 var(--space-10); }
    .essay-title { font-family: var(--font-serif); font-weight: 300; font-size: clamp(42px, 5.6vw, 76px); line-height: 1.02; letter-spacing: -0.025em; font-variation-settings: 'opsz' 144, 'SOFT' 30; color: var(--ink); margin: 0; max-width: 820px; }
    .essay-title em { font-style: italic; font-weight: 400; font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1; }
    .essay-deck { font-family: var(--font-serif); font-style: italic; font-weight: 300; font-size: 22px; line-height: 1.45; color: var(--body); margin: var(--space-7) 0 0; max-width: 660px; font-variation-settings: 'opsz' 36, 'SOFT' 80, 'WONK' 1; }
    .essay-byline { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--tertiary); margin-top: var(--space-8); }
    .essay-body { padding: var(--space-9) 0 var(--space-10); }
    .essay-body p { font-family: var(--font-serif); font-weight: 400; font-size: 18px; line-height: 1.65; color: var(--body); max-width: 660px; margin: 0 0 var(--space-6); font-variation-settings: 'opsz' 14; text-wrap: pretty; }
    .essay-body p strong { font-weight: 500; color: var(--ink); }
    .essay-body p em { font-style: italic; }
    .essay-body p:first-of-type::first-letter { font-family: var(--font-serif); font-weight: 300; font-size: 5.2em; line-height: 0.88; float: left; padding: 6px 12px 0 0; color: var(--ink); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1; }
    .essay-body h2 { font-family: var(--font-serif); font-weight: 400; font-size: 30px; line-height: 1.18; letter-spacing: -0.015em; color: var(--ink); margin: var(--space-10) 0 var(--space-7); font-variation-settings: 'opsz' 96, 'SOFT' 50; max-width: 660px; }
    .essay-body blockquote { font-family: var(--font-serif); font-style: italic; font-weight: 300; font-size: 26px; line-height: 1.35; color: var(--ink); border-left: 3px solid var(--signature); padding: 4px 0 4px var(--space-7); margin: var(--space-9) 0; max-width: 600px; font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1; }
    .ornament { text-align: center; margin: var(--space-9) auto; font-family: var(--font-serif); font-size: 20px; color: var(--tertiary); letter-spacing: 0.6em; line-height: 1; user-select: none; }
    .essay-body ol, .essay-body ul { margin: 0 0 var(--space-6); padding-left: var(--space-7); }
    .essay-body ol li, .essay-body ul li { font-family: var(--font-serif); font-size: 18px; line-height: 1.65; color: var(--body); margin-bottom: var(--space-4); font-variation-settings: 'opsz' 14; }
    .essay-body figure { margin: var(--space-9) 0; }
    .essay-body figure img { max-width: 100%; height: auto; display: block; }
    .essay-body figure figcaption { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; color: var(--tertiary); margin-top: var(--space-4); }
    .essay-end { margin-top: var(--space-9); padding-top: var(--space-7); border-top: 1px solid var(--rule); }
    .essay-end .signoff { font-family: var(--font-serif); font-style: italic; font-size: 16.5px; line-height: 1.5; color: var(--tertiary); font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1; max-width: 600px; }
    .essay-end .author { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--tertiary); margin-top: var(--space-6); }
    .more { border-top: 1px solid var(--rule); padding: var(--space-10) 0 var(--space-9); }
    .more .more-eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--tertiary); margin-bottom: var(--space-8); }
    .more-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--space-9); }
    .more-grid .essay-card { text-decoration: none; color: inherit; display: block; }
    .more-grid .essay-card .meta { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--tertiary); margin-bottom: var(--space-5); }
    .more-grid .essay-card .title { font-family: var(--font-serif); font-weight: 400; font-size: 22px; line-height: 1.22; letter-spacing: -0.015em; color: var(--ink); font-variation-settings: 'opsz' 48, 'SOFT' 50; margin: 0 0 var(--space-3); }
    .more-grid .essay-card .deck { font-family: var(--font-serif); font-style: italic; font-size: 16.5px; line-height: 1.5; color: var(--body); margin: 0; font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1; }
    .more-grid .essay-card:hover .title { color: var(--tertiary); }
    .all-link { margin-top: var(--space-9); }
    .all-link a { font-family: var(--font-serif); font-size: 18px; color: var(--ink); text-decoration: underline; text-underline-offset: 4px; text-decoration-thickness: 1px; }
    @media (max-width: 720px) { .more-grid { grid-template-columns: 1fr; gap: var(--space-8); } }
  </style>

  <div class="read-bar" id="read-bar" aria-hidden="true"></div>

  <div class="reading-column essay-top">
    <div class="row">
      <a class="back" href="/writing">— Back to writing</a>
      <div class="meta">
        <span>Q1 2016</span>
        <span class="sep">·</span>
        <span>Essay</span>
        <span class="sep">·</span>
        <span>9 min read</span>
      </div>
    </div>
  </div>

  <div class="reading-column essay-title-block">
    <h1 class="essay-title">
      The Triforce of UX: Part I — <em>Empathy</em>
    </h1>
    <p class="essay-deck">
      Three qualities to seek in your next UX designer. Part one: why empathy is the foundational skill, and three questions to find out if a candidate actually has it.
    </p>
    <div class="essay-byline">— By Brandon E. B. Ward —</div>
  </div>

  <article class="reading-column essay-body">

    <figure>
      <img src="/images/writing/dangerous.jpeg" alt="It's dangerous to go alone" />
    </figure>

    <p>
      After two great years with Improving, I took a leap and joined Precocity. Leaving also meant leaving my client — one of those rare golden consultant/client relationships where we'd been in sync from the start. When I departed, the client wanted to hire an in-house UX designer who could meet or exceed what we'd built together. They asked me two questions: What three skills are most important for a UX designer? And how would you phrase interview questions to validate those skills?
    </p>

    <p>
      As I started to answer, I realized I had strong opinions I'd never formalized. Then a friend asked me the same questions from the candidate's perspective. This three-part series was born.
    </p>

    <h2>The Triforce</h2>

    <figure>
      <img src="/images/writing/triforce.jpeg" alt="The Triforce" />
    </figure>

    <p>
      In Nintendo's <em>The Legend of Zelda</em>, the Triforce is an omnipotent sacred relic. Each triangle represents a piece — <strong>Power</strong>, <strong>Wisdom</strong>, and <strong>Courage</strong> — and they become whole only when combined. In my view, the Triforce of UX consists of <strong>Empathy</strong>, <strong>Curiosity</strong>, and <strong>Humility</strong>. Part I covers Empathy.
    </p>

    <figure>
      <img src="/images/writing/triforce-ux.jpeg" alt="The Triforce of UX" />
    </figure>

    <h2>Part I: The Triforce of Empathy</h2>

    <figure>
      <img src="/images/writing/triforce-empathy.jpeg" alt="The Triforce of Empathy" />
    </figure>

    <p>
      In <em>The Legend of Zelda</em>, your health is measured in hearts. More hearts means more strength, longer life, better endurance in battle. The same is true in UX.
    </p>

    <p>
      When considering a UX candidate, ask: Does this person know how to get into the heads and hearts of users, developers, and stakeholders? Can they walk a mile in their shoes? Or is this a <strong><em>MY</em></strong>X designer — a UX designer without the U — who thinks the answers to every question live in their own background and experience?
    </p>

    <p>
      Empathy in UX isn't just about users. The best designers are good negotiators, mediators, and bridge-builders. The UX designer is the hub around which business, development, and user needs turn. They don't make enemies — they make allies. They build relationships of trust and accountability. Everyone needs to feel free to bring their gnarliest problems to the UX designer.
    </p>

    <h2>Three empathy questions for candidates</h2>

    <figure>
      <img src="/images/writing/piechart.jpeg" alt="What a UX Designer Actually Does" />
      <figcaption>What a UX Designer Actually Does</figcaption>
    </figure>

    <blockquote>
      1. What's your primary goal as a UX designer?
    </blockquote>

    <p>
      Open here, after the ice-breaking. This question reveals if this candidate's mental model of UX aligns with yours. Listen for how they rank their priorities. The answer I want speaks to making people rock stars at their jobs while balancing the needs of the business and the realities of the humans building it. I want to know their passion for creating amazing experiences for people. Most importantly, I want to hear that they put <strong>end-users first</strong>, the <strong>client's business second</strong>, and the <strong>developers</strong> third — never least.
    </p>

    <blockquote>
      2. Tell me about your user-research techniques and methodologies.
    </blockquote>

    <p>
      Here we're delving into soft skills. Can they talk to other humans? Do they have a conscious, purposeful method for open-ended interviews and in-context observation? When do they do research — is it an after-the-fact A/B test, or where they start? The ability to accurately assess users' needs is the primary dictator of whether the product solves anybody's actual problems.
    </p>

    <blockquote>
      3. Who has final say on what a UI looks like, and why?
    </blockquote>

    <p>
      This is a tough one. I know my answer has cost me at least one job offer — and that was a good thing, because the would-be employer's answer was fundamentally different from mine, and the difference would have been a major source of contention. My answer: <strong>the developer</strong>. Decisions are made by those who show up. UIs are designed by those who commit code. Your Sketch file went into the garbage; the code shipped — that's what the user sees. When the designer builds a relationship of trust and accountability with developers, everyone's jobs become exponentially easier. And better.
    </p>

    <div class="essay-end">
      <p class="signoff">
        Read Part II (Curiosity) and Part III (Humility) for the complete Triforce.
      </p>
      <div class="author">— Brandon E. B. Ward · Dallas, TX —</div>
    </div>

  </article>

  <section class="container">
    <div class="more">
      <div class="grid">
        <div class="marker">§ ↗</div>
        <div>
          <div class="more-eyebrow">— More from the writing —</div>
          <div class="more-grid">
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
          </div>
          <div class="all-link">
            <a href="/writing">— All writing →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function () {
      var bar = document.getElementById('read-bar');
      if (!bar) return;
      function update() {
        var doc = document.documentElement;
        var max = (doc.scrollHeight - doc.clientHeight);
        var pct = max > 0 ? Math.min(100, Math.max(0, (doc.scrollTop || window.scrollY) / max * 100)) : 0;
        bar.style.width = pct + '%';
      }
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
    })();
  </script>
</Base>
