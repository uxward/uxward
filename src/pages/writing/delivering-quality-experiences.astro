---
import Base from '../../layouts/Base.astro';
---
<Base title="Delivering Quality Experiences · uxward">
  <style>
    .read-bar {
      position: fixed;
      top: 0; left: 0;
      height: 2px;
      width: 0%;
      background: var(--signature);
      z-index: 200;
      transition: width 80ms linear;
    }

    .reading-column {
      max-width: 660px;
      margin: 0 auto;
      padding: 0 var(--gutter-x);
    }

    .essay-top { padding: var(--space-8) 0 var(--space-7); }
    .essay-top .row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-7);
      flex-wrap: wrap;
    }
    .essay-top a.back,
    .essay-top .meta {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      text-decoration: none;
    }
    .essay-top a.back:hover { color: var(--ink); }
    .essay-top .meta .sep { padding: 0 12px; color: var(--rule); }

    .essay-title-block { padding: var(--space-9) 0 var(--space-10); }
    .essay-title {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: clamp(42px, 5.6vw, 76px);
      line-height: 1.02;
      letter-spacing: -0.025em;
      font-variation-settings: 'opsz' 144, 'SOFT' 30;
      color: var(--ink);
      margin: 0;
      max-width: 820px;
    }
    .essay-title em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    }
    .essay-deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: 22px;
      line-height: 1.45;
      color: var(--body);
      margin: var(--space-7) 0 0;
      max-width: 660px;
      font-variation-settings: 'opsz' 36, 'SOFT' 80, 'WONK' 1;
    }
    .essay-byline {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-top: var(--space-8);
    }

    .essay-body { padding: var(--space-9) 0 var(--space-10); }
    .essay-body p {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 18px;
      line-height: 1.65;
      color: var(--body);
      max-width: 660px;
      margin: 0 0 var(--space-6);
      font-variation-settings: 'opsz' 14;
      text-wrap: pretty;
    }
    .essay-body p strong { font-weight: 500; color: var(--ink); }
    .essay-body p em { font-style: italic; }
    .essay-body p:first-of-type::first-letter {
      font-family: var(--font-serif);
      font-weight: 300;
      font-size: 5.2em;
      line-height: 0.88;
      float: left;
      padding: 6px 12px 0 0;
      color: var(--ink);
      font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
    }
    .essay-body h2 {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 30px;
      line-height: 1.18;
      letter-spacing: -0.015em;
      color: var(--ink);
      margin: var(--space-10) 0 var(--space-7);
      font-variation-settings: 'opsz' 96, 'SOFT' 50;
      max-width: 660px;
    }
    .essay-body h2 em {
      font-style: italic; font-weight: 400;
      font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1;
    }
    .essay-body blockquote {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: 26px;
      line-height: 1.35;
      color: var(--ink);
      border-left: 3px solid var(--signature);
      padding: 4px 0 4px var(--space-7);
      margin: var(--space-9) 0;
      max-width: 600px;
      font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1;
    }
    .ornament {
      text-align: center;
      margin: var(--space-9) auto;
      font-family: var(--font-serif);
      font-size: 20px;
      color: var(--tertiary);
      letter-spacing: 0.6em;
      line-height: 1;
      user-select: none;
    }
    .essay-body figure { margin: var(--space-9) 0; }
    .essay-body figure img { max-width: 100%; height: auto; display: block; }
    .essay-body figure figcaption {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      color: var(--tertiary);
      margin-top: var(--space-4);
    }

    .essay-end {
      margin-top: var(--space-9);
      padding-top: var(--space-7);
      border-top: 1px solid var(--rule);
    }
    .essay-end .author {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-top: var(--space-6);
    }

    .more {
      border-top: 1px solid var(--rule);
      padding: var(--space-10) 0 var(--space-9);
    }
    .more .more-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-8);
    }
    .more-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: var(--space-9);
    }
    .more-grid .essay-card {
      text-decoration: none; color: inherit; display: block;
    }
    .more-grid .essay-card .meta {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--tertiary);
      margin-bottom: var(--space-5);
    }
    .more-grid .essay-card .title {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: 22px;
      line-height: 1.22;
      letter-spacing: -0.015em;
      color: var(--ink);
      font-variation-settings: 'opsz' 48, 'SOFT' 50;
      margin: 0 0 var(--space-3);
    }
    .more-grid .essay-card .deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 16.5px;
      line-height: 1.5;
      color: var(--body);
      margin: 0;
      font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1;
    }
    .more-grid .essay-card:hover .title { color: var(--tertiary); }

    .all-link { margin-top: var(--space-9); }
    .all-link a {
      font-family: var(--font-serif);
      font-size: 18px;
      color: var(--ink);
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-thickness: 1px;
    }

    @media (max-width: 720px) {
      .more-grid { grid-template-columns: 1fr; gap: var(--space-8); }
    }
  </style>

  <div class="read-bar" id="read-bar" aria-hidden="true"></div>

  <div class="reading-column essay-top">
    <div class="row">
      <a class="back" href="/writing">— Back to writing</a>
      <div class="meta">
        <span>Q2 2021</span>
        <span class="sep">·</span>
        <span>Essay</span>
        <span class="sep">·</span>
        <span>10 min read</span>
      </div>
    </div>
  </div>

  <div class="reading-column essay-title-block">
    <h1 class="essay-title">
      Delivering <em>Quality</em> Experiences
    </h1>
    <p class="essay-deck">
      Most design processes look good on paper. The road to destruction is paved with good intentions — and HiPPO feedback.
    </p>
    <div class="essay-byline">— By Brandon E. B. Ward —</div>
  </div>

  <article class="reading-column essay-body">

    <figure>
      <img src="/images/writing/michaela-baum-VnM6_liIRJ0-unsplash.jpg" alt="Designer at work — Photo by Michaela Baum on Unsplash" />
      <figcaption>Photo by Michaela Baum on Unsplash</figcaption>
    </figure>

    <p>
      There is a well-worn design process that most teams follow — or claim to follow. It looks reasonable in a deck. It falls apart in practice. The gap between "our process" and "what we actually ship" is where quality goes to die.
    </p>

    <h2>The Basic Design Process</h2>

    <figure>
      <img src="/images/writing/make+the+logo+bigger" alt="Make the logo bigger — the client's favorite note" />
    </figure>

    <p>
      The basic design process starts with research: understanding users, their goals, their pain points, the context in which they operate. From research you move to synthesis — finding the patterns, the gaps, the real problem underneath the stated problem. Then ideation: generating many possible solutions before converging on the most promising. Then design and prototype: making ideas tangible enough to test. Then testing: putting designs in front of real users to validate or invalidate assumptions. Then iteration: improving based on what you learned. Then delivery: shipping something that actually works.
    </p>

    <p>
      Simple. Elegant. Sensible.
    </p>

    <figure>
      <img src="/images/writing/leon-vbxyFxlgpjM-unsplash.jpg" alt="Empty road — Photo by Leon on Unsplash" />
      <figcaption>Photo by Leon on Unsplash</figcaption>
    </figure>

    <h2>The Road to Destruction</h2>

    <p>
      Now here is what actually happens. The research phase gets cut because there is no time. Synthesis skips because there is no budget. Ideation becomes a single round of wireframes that someone already had in their head. The prototype is a PDF. Testing means showing it to a few colleagues who give polite feedback. Iteration means making the logo bigger. Delivery means shipping the thing you started with, lightly rearranged.
    </p>

    <figure>
      <img src="/images/writing/amelie-mourichon-sv8oOQaUb-o-unsplash.jpg" alt="Chaos — Photo by Amelie Mourichon on Unsplash" />
      <figcaption>Photo by Amelie Mourichon on Unsplash</figcaption>
    </figure>

    <p>
      The culprit is usually the HiPPO: the Highest Paid Person's Opinion. HiPPO feedback bypasses the process entirely. It doesn't matter what the research says, what users need, what the data shows. If the person with the most authority has a gut feeling, the process stops and the team pivots. The result is a product shaped by seniority, not by evidence.
    </p>

    <figure>
      <img src="/images/writing/ux-indonesia-5QiGvmyJTsc-unsplash.jpg" alt="UX team working — Photo by UX Indonesia on Unsplash" />
      <figcaption>Photo by UX Indonesia on Unsplash</figcaption>
    </figure>

    <blockquote>
      The road to destruction is paved with HiPPO opinions and good intentions.
    </blockquote>

    <figure>
      <img src="/images/writing/daniel-korpai-iopITwyUcTA-unsplash.jpg" alt="Design on screen — Photo by Daniel Korpai on Unsplash" />
      <figcaption>Photo by Daniel Korpai on Unsplash</figcaption>
    </figure>

    <p>
      There is also the anti-pattern of novelty for its own sake. Introducing new interaction patterns, unusual layouts, or custom behaviors where standard ones would serve better. This is how you get the web equivalent of LingsCars.com.
    </p>

    <figure>
      <img src="/images/writing/lingscars.jpg" alt="LingsCars.com — a masterclass in anti-UX" />
      <figcaption>LingsCars.com — a cautionary tale</figcaption>
    </figure>

    <h2>The Path to Quality</h2>

    <figure>
      <img src="/images/writing/UX-hierarchy-of-needs-model.jpg" alt="UX Hierarchy of Needs model" />
    </figure>

    <p>
      Quality experiences satisfy user needs at every level of the UX hierarchy. At the base: functional. The thing works. Above that: reliable. It works consistently. Above that: usable. People can figure it out without a manual. Above that: convenient. It fits into their life without friction. At the top: pleasurable and meaningful. It makes people feel something good.
    </p>

    <p>
      Most products never make it past "functional." Some never even get there. The ones that earn loyalty — the ones people recommend to friends — are the ones that reach the top of the pyramid.
    </p>

    <h2>The Cupcake Model of MVP</h2>

    <figure>
      <img src="/images/writing/cupcake.jpg" alt="Cupcake — the right MVP metaphor" />
    </figure>

    <p>
      The most useful mental model for scope management is the cupcake. Not the birthday cake. Not the wedding cake. The cupcake.
    </p>

    <p>
      The birthday cake analogy for MVP says: don't build a birthday cake — just build a cupcake. A cupcake is a complete, delightful thing on its own. It has cake, frosting, maybe a decoration. It satisfies the craving. The birthday cake is the full vision — the right product for the right moment — but you don't start there.
    </p>

    <figure>
      <img src="/images/writing/mvp-cut.jpg" alt="MVP cut diagram" />
    </figure>

    <p>
      The bad version of this is building a slice of birthday cake. A slice of birthday cake without the rest of the cake is not a product. It is a fragment. It does not stand alone. Users cannot do anything useful with it. Shipping a feature slice instead of a complete small experience is the most common MVP mistake.
    </p>

    <p>
      Build the cupcake. Validate it. Then decide if the market wants a birthday cake or a wedding cake. Don't build the wedding cake first and hope someone shows up to the reception.
    </p>

    <div class="essay-end">
      <div class="author">— Brandon E. B. Ward · Dallas, TX —</div>
    </div>

  </article>

  <section class="container">
    <div class="more">
      <div class="grid">
        <div class="marker">§ ↗</div>
        <div>
          <div class="more-eyebrow">— More from the writing —</div>
          <div class="more-grid">
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
          </div>
          <div class="all-link">
            <a href="/writing">— All writing →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function () {
      var bar = document.getElementById('read-bar');
      if (!bar) return;
      function update() {
        var doc = document.documentElement;
        var max = (doc.scrollHeight - doc.clientHeight);
        var pct = max > 0 ? Math.min(100, Math.max(0, (doc.scrollTop || window.scrollY) / max * 100)) : 0;
        bar.style.width = pct + '%';
      }
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
    })();
  </script>
</Base>
