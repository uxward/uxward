---
import Base from '../../layouts/Base.astro';
import { essays, essaySections, essaysNewestFirst, plainTitle } from '../../data/essays.js';
// Topic-tag labels for the Date view: section titles minus the "On " prefix.
const tagLabel = Object.fromEntries(essaySections.map((s) => [s.key, s.title.replace(/^On\s+/, '')]));
---
<Base title="Writing · uxward">
  <style>
    .writing-top { padding-top: var(--space-8); padding-bottom: var(--space-6); }
    .writing-top a.back { font-weight: 600; font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--tertiary); text-decoration: none; }
    .writing-top a.back:hover { color: var(--signature); }

    .head { padding-top: var(--space-7); padding-bottom: var(--space-8); border-bottom: 1px solid var(--rule-faint); }
    .head-eyebrow { font-weight: 700; font-size: 13px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--ink); margin-bottom: var(--space-7); }
    .head-h { font-weight: 900; font-size: clamp(48px, 6.4vw, 84px); line-height: 0.96; letter-spacing: -0.04em; color: var(--ink); margin: 0; max-width: 18ch; }
    .head-h em { font-style: normal; }
    .head-intro { font-weight: 400; font-size: 21px; line-height: 1.5; color: var(--body); max-width: 60ch; margin: var(--space-6) 0 0; }

    /* ---------- Controls band (toggle left · filter right) ---------- */
    .controls { padding: var(--space-9) 0 var(--space-4); }
    .controls-row { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-7); }
    .viewtoggle { display: flex; align-items: baseline; gap: var(--space-4); white-space: nowrap; }
    .vt-label { font-weight: 600; font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--tertiary); }
    .vt-btn { background: none; border: 0; padding: 0; cursor: pointer; font-weight: 600; font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--tertiary); transition: color var(--t-fast) ease; }
    .vt-btn.is-active { color: var(--ink); text-decoration: underline; text-underline-offset: 4px; text-decoration-thickness: 1px; }
    .vt-btn:hover { color: var(--signature); }
    .vt-div { color: var(--rule-faint); }

    .search { width: 320px; max-width: 100%; padding-bottom: 10px; border-bottom: 1px solid var(--ink); transition: border-color var(--t-fast) ease; }
    .search:focus-within { border-bottom-color: var(--signature); }
    .search-row { display: grid; grid-template-columns: auto 1fr auto; align-items: baseline; gap: 14px; }
    .search-label { font-weight: 600; font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--tertiary); }
    .search-input { border: 0; outline: 0; background: transparent; font-size: 18px; color: var(--ink); padding: 4px 0; width: 100%; }
    .search-input::placeholder { color: var(--tertiary); opacity: 0.6; transition: opacity var(--t-fast) ease; }
    .search-input:focus::placeholder { opacity: 0; }
    .search-clear { background: none; border: 0; cursor: pointer; font-size: 18px; color: var(--tertiary); line-height: 1; padding: 0 2px; visibility: hidden; }
    .search.has-text .search-clear { visibility: visible; }
    .search-clear:hover { color: var(--signature); }
    .search-hint { margin-top: 10px; font-weight: 600; font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--tertiary); min-height: 14px; text-align: right; }

    /* ---------- Featured pull ---------- */
    .featured { padding: var(--space-10) 0; border-bottom: 1px solid var(--rule-faint); }
    .featured-grid { display: grid; grid-template-columns: var(--gutter-mark) 1fr; gap: var(--space-7); }
    .featured-mark { font-weight: 700; font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--signature); padding-top: 0; border-left: 3px solid var(--signature); padding-left: var(--space-5); }
    .featured-eyebrow { font-weight: 700; font-size: 13px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--ink); margin-bottom: var(--space-6); }
    .featured-eyebrow .dot { color: var(--signature); padding: 0 6px; }
    a.featured-link { text-decoration: none; color: inherit; display: block; }
    a.featured-link h2 { font-weight: 900; font-size: clamp(40px, 4.8vw, 60px); line-height: 1.0; letter-spacing: -0.035em; color: var(--ink); margin: 0; max-width: 880px; transition: color var(--t-fast) ease; }
    a.featured-link h2 em { font-style: normal; }
    .featured-deck { font-weight: 400; font-size: 22px; line-height: 1.5; color: var(--body); max-width: 700px; margin: var(--space-6) 0 0; }
    .featured-excerpt { font-style: italic; font-weight: 400; font-size: 18px; line-height: 1.65; color: var(--tertiary); max-width: 640px; margin: var(--space-7) 0 0; padding-left: var(--space-5); border-left: 1px solid var(--rule-faint); }
    .featured-cta { display: inline-block; margin-top: var(--space-7); font-weight: 700; font-size: 14px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--ink); text-decoration: none; }
    a.featured-link:hover h2 { color: var(--signature); }
    a.featured-link:hover .featured-cta { color: var(--signature); }

    /* ---------- List + view swap ---------- */
    .list { padding-top: var(--space-4); padding-bottom: var(--space-10); }
    .list[data-view="topic"] #view-date { display: none; }
    .list[data-view="date"] #view-topic { display: none; }
    /* view cross-fade: dip the active view out, swap, fade the new one in */
    #view-topic, #view-date { transition: opacity 120ms ease; }
    .list.vw-leaving #view-topic, .list.vw-leaving #view-date,
    .list.vw-entering #view-topic, .list.vw-entering #view-date { opacity: 0; }

    /* ---------- Sections (Topic view — always open) ---------- */
    .section { padding: var(--space-9) 0 var(--space-8); }
    .section + .section { border-top: 1px solid var(--rule-faint); }
    .section-head { display: grid; grid-template-columns: var(--gutter-mark) 1fr; gap: var(--space-7); align-items: baseline; }
    .section-mark { font-weight: 900; font-size: 22px; letter-spacing: -0.02em; color: var(--signature); padding-top: 8px; font-feature-settings: 'tnum' 1; }
    .section-title h2 { font-weight: 800; font-size: 36px; line-height: 1.1; letter-spacing: -0.025em; color: var(--ink); margin: 0; }
    .section-descriptor { font-weight: 400; font-size: 16px; line-height: 1.5; color: var(--tertiary); margin: var(--space-3) 0 0; max-width: 580px; }
    .section-rule { border: 0; border-top: 1px solid var(--rule-faint); margin: var(--space-7) 0 0; }
    .section-body { display: grid; grid-template-columns: var(--gutter-mark) 1fr; gap: var(--space-7); }
    .essays { grid-column: 2; padding-top: var(--space-6); }
    .section-empty-msg, .flat-empty-msg { grid-column: 2; font-weight: 600; font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--tertiary); display: none; }
    .section.no-matches .essays { display: none; }
    .section.no-matches .section-empty-msg { display: block; padding-top: var(--space-5); }

    /* ---------- Date view (flat list) ---------- */
    #view-date { padding-top: var(--space-9); }
    #view-date.no-matches .essays { display: none; }
    #view-date.no-matches .flat-empty-msg { display: block; padding-top: var(--space-5); }

    /* ---------- Row — table-of-contents line ---------- */
    a.essay {
      display: block;
      text-decoration: none;
      color: inherit;
      padding: var(--space-5) 0;
      max-height: 400px;
      overflow: hidden;
      opacity: 1;
      visibility: visible;
      transition: max-height 150ms ease, padding 150ms ease, opacity 150ms ease 150ms, visibility 0s;
    }
    a.essay.filtered-out {
      opacity: 0;
      max-height: 0;
      padding-top: 0;
      padding-bottom: 0;
      pointer-events: none;
      visibility: hidden;
      transition: opacity 150ms ease, max-height 150ms ease 150ms, padding 150ms ease 150ms, visibility 0s 300ms;
    }
    .essay-line { display: flex; align-items: baseline; }
    .essay-title { flex: 0 1 auto; font-weight: 700; font-size: 22px; line-height: 1.2; letter-spacing: -0.018em; color: var(--ink); transition: color var(--t-fast) ease; }
    .essay-title em { font-style: normal; }
    .essay-lead {
      flex: 1 1 auto;
      align-self: baseline;
      margin: 0 var(--space-5);
      min-width: 24px;
      height: 1px;
      background-image: radial-gradient(circle, var(--rule-faint) 0.6px, transparent 0.7px);
      background-size: 8px 1px;
      background-repeat: repeat-x;
      background-position: 0 center;
      position: relative;
      top: -0.22em;
    }
    .essay-quarter { flex: 0 0 auto; white-space: nowrap; font-weight: 600; font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--tertiary); }
    .essay-deck {
      display: block;
      font-size: 16px;
      line-height: 1.5;
      color: var(--body);
      margin: 8px 0 0;
      max-width: 620px;
      opacity: 0;
      transition: opacity var(--t-fast) ease;
    }
    a.essay:hover .essay-title,
    a.essay:focus-visible .essay-title { color: var(--signature); }
    a.essay:hover .essay-deck,
    a.essay:focus-visible .essay-deck { opacity: 1; }
    a.essay:focus-visible { outline: 2px solid var(--signature); outline-offset: 3px; }

    .pivot { padding: var(--space-9) 0; border-top: 1px solid var(--rule-faint); }
    .pivot-grid { display: grid; grid-template-columns: var(--gutter-mark) 1fr; gap: var(--space-7); }
    .pivot-mark { font-weight: 700; font-size: 13px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--tertiary); padding-top: 14px; }
    a.pivot-link { display: block; text-decoration: none; color: inherit; }
    .pivot-link .label { font-weight: 800; font-size: 36px; line-height: 1.1; letter-spacing: -0.025em; color: var(--ink); }
    .pivot-link .label em { font-style: normal; }
    .pivot-link .why { font-weight: 400; font-size: 17px; color: var(--body); margin: var(--space-4) 0 0; max-width: 520px; }
    .pivot-link:hover .label,
    .pivot-link:focus-visible .label { color: var(--signature); }

    @media (max-width: 880px) {
      .controls-row { flex-direction: column; align-items: stretch; gap: var(--space-5); }
      .search { width: auto; }
      .search-hint { text-align: left; }

      /* § numerals inline above each section title */
      .section-head { grid-template-columns: 1fr; gap: var(--space-3); }
      .section-mark { padding-top: 0; }
      .section-body { grid-template-columns: 1fr; }
      .essays { grid-column: auto; }
      .section-empty-msg, .flat-empty-msg { grid-column: auto; }

      /* rows stack: title full width, quarter below, leader dropped */
      .essay-line { flex-wrap: wrap; }
      .essay-lead { display: none; }
      .essay-title { flex: 1 1 100%; }
      .essay-quarter { flex-basis: 100%; margin-top: 6px; }
    }
  </style>

  <div class="container writing-top">
    <div class="grid">
      <div class="marker">↩</div>
      <div><a class="back" href="/">Back home</a></div>
    </div>
  </div>

  <section class="head">
    <div class="container">
    <div class="head-eyebrow">Writing · {essays.length} essays · Occaisionally</div>
    <h1 class="head-h">Writing, <em>arranged by what it argues.</em></h1>
    <p class="head-intro">
      This is where I write about design leadership, the craft itself, the research
      that shapes both, and where AI is taking us. Periodically. Long-form (usually). No newsletter
      to sign up for.
    </p>
    </div>
  </section>

  <section class="featured" id="featured">
    <div class="container">
    <div class="featured-grid">
      <div class="featured-mark">Featured</div>
      <div>
        <div class="featured-eyebrow">On Experience Design <span class="dot">·</span> Q1 2026</div>
        <a class="featured-link" href="/writing/only-you-can-prevent-dumpster-fires">
          <h2>Only You Can Prevent <em>Dumpster Fires.</em></h2>
          <p class="featured-deck">
            A design ethics manifesto in five parts. The fires are preventable.
            The choice to prevent them is yours.
          </p>
          <p class="featured-excerpt">
            Bad design doesn't happen because designers are bad people. It happens
            because good designers stay quiet at the wrong moment.
          </p>
          <span class="featured-cta">Read the essay</span>
        </a>
      </div>
    </div>
    </div>
  </section>

  <section class="controls">
    <div class="container">
    <div class="controls-row">
      <div class="viewtoggle" role="group" aria-label="Arrange essays">
        <span class="vt-label">Arrange</span>
        <button type="button" class="vt-btn is-active" data-view-btn="topic" aria-pressed="true">Topic</button>
        <span class="vt-div" aria-hidden="true">|</span>
        <button type="button" class="vt-btn" data-view-btn="date" aria-pressed="false">Date</button>
      </div>
      <form class="search" role="search" onsubmit="return false;">
        <div class="search-row">
          <span class="search-label">Find</span>
          <input id="search-input" class="search-input" type="text" autocomplete="off"
                 placeholder="Filter essays" aria-label="Filter essays">
          <button type="button" class="search-clear" id="search-clear" aria-label="Clear filter">×</button>
        </div>
      </form>
    </div>
    <div class="search-hint" id="search-hint" aria-live="polite"></div>
    </div>
  </section>

  <main class="list" data-view="topic">
    <div id="view-topic">
      {essaySections.map((s, i) => (
        <section class="section" data-section={s.key}>
          <div class="container">
          <div class="section-head">
            <div class="section-mark">{String(i + 1).padStart(2, '0')}</div>
            <div class="section-title">
              <h2>{s.title}</h2>
              <p class="section-descriptor">{s.descriptor}</p>
              <hr class="section-rule" />
            </div>
          </div>
          <div class="section-body">
            <div class="essays">
              {essays.filter((e) => e.section === s.key).map((e) => (
                <a class="essay" href={`/writing/${e.slug}`}
                   data-title={plainTitle(e.title)}
                   data-deck={e.deck}>
                  <span class="essay-line">
                    <span class="essay-title" set:html={e.title} />
                    <span class="essay-lead" aria-hidden="true"></span>
                    <span class="essay-quarter">{e.quarter}</span>
                  </span>
                  <span class="essay-deck">{e.deck}</span>
                </a>
              ))}
            </div>
            <div class="section-empty-msg">No matches in {s.title}.</div>
          </div>
          </div>
        </section>
      ))}
    </div>

    <div id="view-date">
      <div class="container">
      <div class="section-body">
        <div class="essays">
          {essaysNewestFirst.map((e) => (
            <a class="essay" href={`/writing/${e.slug}`}
               data-title={plainTitle(e.title)}
               data-deck={e.deck}>
              <span class="essay-line">
                <span class="essay-title" set:html={e.title} />
                <span class="essay-lead" aria-hidden="true"></span>
                <span class="essay-quarter">{tagLabel[e.section]} · {e.quarter}</span>
              </span>
              <span class="essay-deck">{e.deck}</span>
            </a>
          ))}
        </div>
        <div class="flat-empty-msg">No matches.</div>
      </div>
      </div>
    </div>
  </main>

  <section class="pivot">
    <div class="container">
      <div class="pivot-grid">
        <div class="pivot-mark">↗</div>
        <a class="pivot-link" href="/about">
          <div class="label">More <em>about me</em></div>
          <p class="why">The longer recruiter-deep version. Twenty-five years told plainly, with a timeline.</p>
        </a>
      </div>
    </div>
  </section>

  <script>
    (function () {
      var input = document.getElementById('search-input');
      var clear = document.getElementById('search-clear');
      var hint = document.getElementById('search-hint');
      var searchEl = document.querySelector('.search');
      var list = document.querySelector('.list');
      var topicView = document.getElementById('view-topic');
      var dateView = document.getElementById('view-date');
      var btns = Array.prototype.slice.call(document.querySelectorAll('[data-view-btn]'));
      var KEY = 'uxward:writing-view';

      function activeView() { return list.getAttribute('data-view'); }
      function activeContainer() { return activeView() === 'date' ? dateView : topicView; }

      function applyFilter() {
        var q = input.value.trim().toLowerCase();
        var container = activeContainer();
        var rows = container.querySelectorAll('a.essay');
        var total = 0;
        rows.forEach(function (r) {
          var t = (r.getAttribute('data-title') || '').toLowerCase();
          var d = (r.getAttribute('data-deck') || '').toLowerCase();
          var ok = !q || t.indexOf(q) !== -1 || d.indexOf(q) !== -1;
          r.classList.toggle('filtered-out', !ok);
          if (ok) total++;
        });

        if (activeView() === 'topic') {
          topicView.querySelectorAll('.section').forEach(function (sec) {
            var m = 0;
            sec.querySelectorAll('a.essay').forEach(function (r) { if (!r.classList.contains('filtered-out')) m++; });
            sec.classList.toggle('no-matches', !!q && m === 0);
          });
        } else {
          dateView.classList.toggle('no-matches', !!q && total === 0);
        }

        var filtering = !!q;
        searchEl.classList.toggle('has-text', filtering);

        if (filtering) {
          hint.textContent = total + (total === 1 ? ' essay' : ' essays');
        } else {
          hint.textContent = '';
        }
      }

      function resetAll() {
        input.value = '';
        applyFilter();
        input.focus();
      }

      var mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');
      var swapTimer = null;

      function updateButtons(v) {
        btns.forEach(function (b) {
          var on = b.getAttribute('data-view-btn') === v;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
      }

      function setView(v, persist, animate) {
        if (persist) { try { localStorage.setItem(KEY, v); } catch (e) {} }
        updateButtons(v);
        var cur = list.getAttribute('data-view');
        if (!animate || mqReduce.matches || v === cur) {
          list.setAttribute('data-view', v);
          applyFilter();
          return;
        }
        if (swapTimer) { clearTimeout(swapTimer); list.classList.remove('vw-leaving', 'vw-entering'); }
        list.classList.add('vw-leaving');                 // dip current view out
        swapTimer = setTimeout(function () {
          list.classList.remove('vw-leaving');
          list.setAttribute('data-view', v);              // swap which view shows
          applyFilter();
          list.classList.add('vw-entering');              // new view starts transparent
          requestAnimationFrame(function () {
            requestAnimationFrame(function () { list.classList.remove('vw-entering'); });
          });
          swapTimer = null;
        }, 130);
      }

      btns.forEach(function (b) {
        b.addEventListener('click', function () { setView(b.getAttribute('data-view-btn'), true, true); });
      });
      input.addEventListener('input', applyFilter);
      clear.addEventListener('click', resetAll);

      var saved;
      try { saved = localStorage.getItem(KEY); } catch (e) {}
      setView(saved === 'date' ? 'date' : 'topic', false, false);
    })();
  </script>
</Base>
