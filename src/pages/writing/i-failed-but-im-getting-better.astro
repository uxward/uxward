---
import Base from '../../layouts/Base.astro';
---
<Base title="I Failed. But I'm Getting Better. · uxward">
  <style>
    .read-bar { position: fixed; top: 0; left: 0; height: 2px; width: 0%; background: var(--signature); z-index: 200; transition: width 80ms linear; }
    .reading-column { max-width: 660px; margin: 0 auto; padding: 0 var(--gutter-x); }
    .essay-top { padding: var(--space-8) 0 var(--space-7); }
    .essay-top .row { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-7); flex-wrap: wrap; }
    .essay-top a.back, .essay-top .meta { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--tertiary); text-decoration: none; }
    .essay-top a.back:hover { color: var(--ink); }
    .essay-top .meta .sep { padding: 0 12px; color: var(--rule); }
    .essay-title-block { padding: var(--space-9) 0 var(--space-10); }
    .essay-title { font-family: var(--font-serif); font-weight: 300; font-size: clamp(42px, 5.6vw, 76px); line-height: 1.02; letter-spacing: -0.025em; font-variation-settings: 'opsz' 144, 'SOFT' 30; color: var(--ink); margin: 0; max-width: 820px; }
    .essay-title em { font-style: italic; font-weight: 400; font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1; }
    .essay-deck { font-family: var(--font-serif); font-style: italic; font-weight: 300; font-size: 22px; line-height: 1.45; color: var(--body); margin: var(--space-7) 0 0; max-width: 660px; font-variation-settings: 'opsz' 36, 'SOFT' 80, 'WONK' 1; }
    .essay-byline { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--tertiary); margin-top: var(--space-8); }
    .essay-body { padding: var(--space-9) 0 var(--space-10); }
    .essay-body p { font-family: var(--font-serif); font-weight: 400; font-size: 18px; line-height: 1.65; color: var(--body); max-width: 660px; margin: 0 0 var(--space-6); font-variation-settings: 'opsz' 14; text-wrap: pretty; }
    .essay-body p strong { font-weight: 500; color: var(--ink); }
    .essay-body p em { font-style: italic; }
    .essay-body p:first-of-type::first-letter { font-family: var(--font-serif); font-weight: 300; font-size: 5.2em; line-height: 0.88; float: left; padding: 6px 12px 0 0; color: var(--ink); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1; }
    .essay-body h2 { font-family: var(--font-serif); font-weight: 400; font-size: 30px; line-height: 1.18; letter-spacing: -0.015em; color: var(--ink); margin: var(--space-10) 0 var(--space-7); font-variation-settings: 'opsz' 96, 'SOFT' 50; max-width: 660px; }
    .essay-body blockquote { font-family: var(--font-serif); font-style: italic; font-weight: 300; font-size: 26px; line-height: 1.35; color: var(--ink); border-left: 3px solid var(--signature); padding: 4px 0 4px var(--space-7); margin: var(--space-9) 0; max-width: 600px; font-variation-settings: 'opsz' 96, 'SOFT' 100, 'WONK' 1; }
    .ornament { text-align: center; margin: var(--space-9) auto; font-family: var(--font-serif); font-size: 20px; color: var(--tertiary); letter-spacing: 0.6em; line-height: 1; user-select: none; }
    .essay-body figure { margin: var(--space-9) 0; }
    .essay-body figure img { max-width: 100%; height: auto; display: block; }
    .essay-body figure figcaption { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; color: var(--tertiary); margin-top: var(--space-4); }
    .essay-end { margin-top: var(--space-9); padding-top: var(--space-7); border-top: 1px solid var(--rule); }
    .essay-end .author { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--tertiary); margin-top: var(--space-6); }
    .more { border-top: 1px solid var(--rule); padding: var(--space-10) 0 var(--space-9); }
    .more .more-eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--tertiary); margin-bottom: var(--space-8); }
    .more-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--space-9); }
    .more-grid .essay-card { text-decoration: none; color: inherit; display: block; }
    .more-grid .essay-card .meta { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--tertiary); margin-bottom: var(--space-5); }
    .more-grid .essay-card .title { font-family: var(--font-serif); font-weight: 400; font-size: 22px; line-height: 1.22; letter-spacing: -0.015em; color: var(--ink); font-variation-settings: 'opsz' 48, 'SOFT' 50; margin: 0 0 var(--space-3); }
    .more-grid .essay-card .deck { font-family: var(--font-serif); font-style: italic; font-size: 16.5px; line-height: 1.5; color: var(--body); margin: 0; font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 1; }
    .more-grid .essay-card:hover .title { color: var(--tertiary); }
    .all-link { margin-top: var(--space-9); }
    .all-link a { font-family: var(--font-serif); font-size: 18px; color: var(--ink); text-decoration: underline; text-underline-offset: 4px; text-decoration-thickness: 1px; }
    @media (max-width: 720px) { .more-grid { grid-template-columns: 1fr; gap: var(--space-8); } }
  </style>

  <div class="read-bar" id="read-bar" aria-hidden="true"></div>

  <div class="reading-column essay-top">
    <div class="row">
      <a class="back" href="/writing">— Back to writing</a>
      <div class="meta">
        <span>Q2 2018</span>
        <span class="sep">·</span>
        <span>Essay</span>
        <span class="sep">·</span>
        <span>9 min read</span>
      </div>
    </div>
  </div>

  <div class="reading-column essay-title-block">
    <h1 class="essay-title">
      I Failed. But I'm <em>Getting Better.</em>
    </h1>
    <p class="essay-deck">
      On being the villain in a story you thought you were the hero of, and what comes after you figure that out.
    </p>
    <div class="essay-byline">— By Brandon E. B. Ward —</div>
  </div>

  <article class="reading-column essay-body">

    <figure>
      <img src="/images/writing/hiker.jpeg" alt="Hiker on a trail — Photo by Paul Gilmore on Unsplash" />
      <figcaption>Photo by Paul Gilmore on Unsplash</figcaption>
    </figure>

    <p>
      This hurts to write. It hurts to fail. A lot. I failed hard a few months ago. But I'm getting better.
    </p>

    <blockquote>
      One day everything is perfect. The next day I'm almost fired.
    </blockquote>

    <p>
      I worked for years to build a relationship with a potential client. Then one day, that relationship bloomed into contractual work. For three months I got to do organizationally challenging, mindset-shifting, real-world-changing work with them. Everything was great. Then I got too comfortable. I got casual in my relationship and, as a result, offended someone and damaged the relationship I'd worked so hard to build.
    </p>

    <p>
      I never got a warning. I never had a one-on-one where they explained what happened. I'm still not quite sure exactly who was offended or why. One day everything was perfect. The next day I was almost fired.
    </p>

    <h2>The Villain Unmasked</h2>

    <p>
      The details aren't really important. My boss was able to share with me third-hand some of what happened. Upon review, the instances seemed contextually trite. But the details don't actually matter. What matters is that others were offended by something I said. It doesn't matter why I did it, or if I didn't mean it. Someone was hurt, and they were hurt by me.
    </p>

    <blockquote>
      I am not the victim in this story. I am the villain.
    </blockquote>

    <p>
      It stings to discover you're the bad guy. Your brain doesn't want to process it and actively works to prevent you from accepting an idea contrary to your currently held biases. It's like that moment when, watching the LEGO Movie, you realize you are President Business. The best evil antagonists in cinema know a little trick: <em>the villain thinks they're the good guy.</em>
    </p>

    <h2>I failed, but I'm not a failure</h2>

    <p>
      As a consultant, you're less than expendable to your client. Sometimes you shoulder the failure of a project even when it wasn't yours. Sometimes you're the target of blame even when you don't deserve it. These are selling points of why clients hire consultants in the first place. I had never had a client relationship go sideways before, and it's easy to forget these facts when things are going well.
    </p>

    <p>
      The fact is: I failed my client by not understanding or empathizing with how they expected our relationship to function. I failed my client by unknowingly hurting them with casual words. I failed my employer by failing my client. I failed my family by failing my employer. I failed myself by failing my family. <strong>I failed, but I'm not a failure.</strong>
    </p>

    <div class="ornament">·  ·  ·</div>

    <h2>A Failure to Empathize</h2>

    <p>
      As an Experience Designer, empathy is one of the key pillars of my practice. Maybe the most critical emotional skill a designer can have. Maybe as a human being, full stop. I lost sight of a critical component of the consultant/client relationship: clients aren't your friends. My role as a consultant is to solve problems and provide value — to ensure they feel they get more value out of our interactions than the fee they paid. That's it. I wasn't able to empathize with my client because I wasn't looking at them through the proper lens. In effect, I'd designed my interactions using the wrong persona.
    </p>

    <h2>So What?</h2>

    <p>
      I'm grateful to my employer for not firing me. We had a radically candid 1:1 where we discussed how and why this all happened, and how we'd ensure the project moved forward under new management to ensure future success. He used this as a teaching moment. That matters enormously.
    </p>

    <p>
      What am I doing about it? Radically shortening the list of topics open for discussion with clients. Weaving a stronger filter between my brain and my mouth. Continuing to improve my active listening skills. We have two ears and one mouth and should use them in a similar ratio.
    </p>

    <p>
      It hurts to grow. A lot. I'm growing now. I'm learning from my failures. I'm thankful for more chances. I will do better.
    </p>

    <p>
      I failed. But I'm getting better. You may fail. But you'll get better too.
    </p>

    <figure>
      <img src="/images/writing/cave.jpeg" alt="Light at the end of a cave" />
    </figure>

    <div class="essay-end">
      <div class="author">— Brandon E. B. Ward · Dallas, TX —</div>
    </div>

  </article>

  <section class="container">
    <div class="more">
      <div class="grid">
        <div class="marker">§ ↗</div>
        <div>
          <div class="more-eyebrow">— More from the writing —</div>
          <div class="more-grid">
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
            <a class="essay-card" href="/writing">
              <div class="meta">— Essay —</div>
              <h3 class="title">More writing</h3>
              <p class="deck">Thoughts on design, leadership, and the work of making things for people.</p>
            </a>
          </div>
          <div class="all-link">
            <a href="/writing">— All writing →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function () {
      var bar = document.getElementById('read-bar');
      if (!bar) return;
      function update() {
        var doc = document.documentElement;
        var max = (doc.scrollHeight - doc.clientHeight);
        var pct = max > 0 ? Math.min(100, Math.max(0, (doc.scrollTop || window.scrollY) / max * 100)) : 0;
        bar.style.width = pct + '%';
      }
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
    })();
  </script>
</Base>
