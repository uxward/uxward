---
import '../styles/global.css';
export interface Props {
  title: string;
  description?: string;
}
const { title, description = "Brandon E. B. Ward — senior design leadership. Building design practice from scratch since 2001." } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <slot name="head" />
  <script is:inline>
    // Apply saved theme before first paint to prevent flash
    (function () {
      try {
        var saved = localStorage.getItem('uxward-theme');
        if (saved === 'dark' || saved === 'light') {
          document.documentElement.setAttribute('data-theme', saved);
        }
      } catch (e) {}
    })();
  </script>
</head>
<body>

  <header class="hdr">
    <div class="container hdr-row">
      <a href="/" class="wm" aria-label="Brandon E.B. Ward"><span class="wm-given">Brandon</span> E.B. Ward</a>
      <div class="hdr-controls">
        <nav class="hdr-nav" aria-label="Main navigation">
          <a href="/work">Work</a>
          <a href="/writing">Writing</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </nav>
        <button id="theme-toggle" class="toggle" title="Toggle theme" aria-label="Toggle theme"><span class="toggle-glyph">—</span></button>
        <button id="menu-toggle" class="menu-toggle" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <div id="nav-overlay" class="nav-overlay" aria-hidden="true">
    <div class="nav-overlay-inner">
      <div class="nav-overlay-top">
        <a href="/" class="wm" aria-label="Brandon E.B. Ward"><span class="wm-given">Brandon</span> E.B. Ward</a>
        <button id="menu-close" class="menu-close" aria-label="Close menu">×</button>
      </div>
      <nav class="nav-overlay-menu" aria-label="Mobile navigation">
        <a href="/work">Work</a>
        <a href="/writing">Writing</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <button class="toggle nav-overlay-toggle" title="Toggle theme" aria-label="Toggle theme"><span class="toggle-glyph">—</span></button>
      </nav>
    </div>
  </div>

  <slot />

  <footer class="foot">
    <div class="container">
      <div class="foot-row">
        <a href="/" class="wm" aria-label="Brandon E.B. Ward"><span class="wm-given">Brandon</span> E.B. Ward</a>
        <nav class="foot-nav" aria-label="Footer navigation">
          <a href="/work">Work</a>
          <a href="/writing">Writing</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/colophon">Colophon</a>
        </nav>
        <div class="foot-ext">
          <a href="https://linkedin.com/in/brandonebward" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://github.com/uxward" target="_blank" rel="noopener">GitHub</a>
          <a href="mailto:brandon@uxward.com">Email</a>
        </div>
      </div>
      <div class="colophon-line">
        <span>— Set in Fraunces &amp; JetBrains Mono · Built with Astro on Cloudflare —</span>
        <span class="fleuron" aria-hidden="true">❦</span>
      </div>
    </div>
  </footer>

  <script>
    (function () {
      var root = document.documentElement;
      var toggles = document.querySelectorAll('.toggle');

      function syncGlyph() {
        var dark = root.getAttribute('data-theme') === 'dark';
        toggles.forEach(function (t) {
          t.classList.toggle('rotating', dark);
          t.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
        });
      }

      syncGlyph();

      toggles.forEach(function (t) {
        t.addEventListener('click', function () {
          var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          root.setAttribute('data-theme', next);
          try { localStorage.setItem('uxward-theme', next); } catch (e) {}
          syncGlyph();
        });
      });

      var menuToggle = document.getElementById('menu-toggle');
      var menuClose = document.getElementById('menu-close');
      var overlay = document.getElementById('nav-overlay');

      function openMenu() {
        overlay.classList.add('is-open');
        overlay.setAttribute('aria-hidden', 'false');
        menuToggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        menuToggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      if (menuToggle) menuToggle.addEventListener('click', openMenu);
      if (menuClose) menuClose.addEventListener('click', closeMenu);

      if (overlay) {
        overlay.querySelectorAll('.nav-overlay-menu a').forEach(function (link) {
          link.addEventListener('click', closeMenu);
        });
      }
    })();
  </script>
</body>
</html>
