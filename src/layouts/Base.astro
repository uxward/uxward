---
import '../styles/global.css';
import '../styles/essay.css';
import '../styles/case.css';
export interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}
const { title, description = "Brandon E. B. Ward — senior design leadership. Building design practice from scratch since 2001.", bodyClass } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <script defer src="/white-rabbit.js"></script>
  <slot name="head" />
  <script is:inline>
    // Apply saved theme before first paint to prevent flash
    (function () {
      try {
        var saved = localStorage.getItem('uxward-theme');
        if (saved === 'dark' || saved === 'light') {
          document.documentElement.setAttribute('data-theme', saved);
        }
        if (localStorage.getItem('uxward-cyber') === '1') {
          var root = document.documentElement;
          root.classList.add('cyber');
          [
            ['rocksalt',  'https://fonts.googleapis.com/css2?family=Rock+Salt&display=swap'],
            ['orbitron',  'https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap'],
            ['sixtyfour', 'https://fonts.googleapis.com/css2?family=Sixtyfour&display=swap'],
          ].forEach(function (p) {
            var l = document.createElement('link');
            l.rel = 'stylesheet'; l.href = p[1];
            l.setAttribute('data-cyberfont', p[0]);
            document.head.appendChild(l);
          });
        }
        // Mid-transition arrival: cover the very first paint so the page
        // swap is invisible — the main script powers it on out of black.
        if (sessionStorage.getItem('uxward-cyber-arriving')) {
          document.documentElement.classList.add('cyber-arriving');
        }
      } catch (e) {}
    })();
  </script>
</head>
<body class={bodyClass}>

  <header class="hdr">
    <div class="container hdr-row">
      <a href="/" class="wm" aria-label="Brandon E.B. Ward"><span class="wm-given">Brandon</span> E.B. Ward</a>
      <div class="hdr-controls">
        <nav class="hdr-nav" aria-label="Main navigation">
          <a href="/work">Work</a>
          <a href="/writing">Writing</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </nav>
        <button id="theme-toggle" class="toggle" title="Toggle theme" aria-label="Toggle theme"><svg class="toggle-glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true" focusable="false"><g class="sun-rays"><line x1="12" y1="3.5" x2="12" y2="6"/><line x1="6.2" y1="6.2" x2="7.9" y2="7.9"/><line x1="17.8" y1="6.2" x2="16.1" y2="7.9"/><line x1="3.5" y1="12" x2="6" y2="12"/><line x1="20.5" y1="12" x2="18" y2="12"/></g><circle class="sun-orb" cx="12" cy="12" r="3.8"/><rect class="sun-cover" x="0" y="18" width="24" height="8" stroke="none"/><line class="sun-horizon" x1="3" y1="18" x2="21" y2="18"/></svg><svg class="cyber-glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10.6"/><g class="rad-blades" fill="currentColor" stroke="none"><path d="M9.94 9.17 L7.18 5.37 A8.2 8.2 0 0 1 16.82 5.37 L14.06 9.17 A3.5 3.5 0 0 0 9.94 9.17 Z"/><path d="M15.48 11.63 L20.16 11.14 A8.2 8.2 0 0 1 15.34 19.49 L13.42 15.20 A3.5 3.5 0 0 0 15.48 11.63 Z"/><path d="M10.58 15.20 L8.66 19.49 A8.2 8.2 0 0 1 3.84 11.14 L8.52 11.63 A3.5 3.5 0 0 0 10.58 15.20 Z"/></g><circle cx="12" cy="12" r="1.7" fill="currentColor" stroke="none"/></svg></button>
        <button id="menu-toggle" class="menu-toggle" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <div id="nav-overlay" class="nav-overlay" aria-hidden="true">
    <div class="nav-overlay-inner">
      <div class="nav-overlay-top">
        <a href="/" class="wm" aria-label="Brandon E.B. Ward"><span class="wm-given">Brandon</span> E.B. Ward</a>
        <button id="menu-close" class="menu-close" aria-label="Close menu">×</button>
      </div>
      <nav class="nav-overlay-menu" aria-label="Mobile navigation">
        <a href="/work">Work</a>
        <a href="/writing">Writing</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <button class="toggle nav-overlay-toggle" title="Toggle theme" aria-label="Toggle theme"><svg class="toggle-glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true" focusable="false"><g class="sun-rays"><line x1="12" y1="3.5" x2="12" y2="6"/><line x1="6.2" y1="6.2" x2="7.9" y2="7.9"/><line x1="17.8" y1="6.2" x2="16.1" y2="7.9"/><line x1="3.5" y1="12" x2="6" y2="12"/><line x1="20.5" y1="12" x2="18" y2="12"/></g><circle class="sun-orb" cx="12" cy="12" r="3.8"/><rect class="sun-cover" x="0" y="18" width="24" height="8" stroke="none"/><line class="sun-horizon" x1="3" y1="18" x2="21" y2="18"/></svg><svg class="cyber-glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10.6"/><g class="rad-blades" fill="currentColor" stroke="none"><path d="M9.94 9.17 L7.18 5.37 A8.2 8.2 0 0 1 16.82 5.37 L14.06 9.17 A3.5 3.5 0 0 0 9.94 9.17 Z"/><path d="M15.48 11.63 L20.16 11.14 A8.2 8.2 0 0 1 15.34 19.49 L13.42 15.20 A3.5 3.5 0 0 0 15.48 11.63 Z"/><path d="M10.58 15.20 L8.66 19.49 A8.2 8.2 0 0 1 3.84 11.14 L8.52 11.63 A3.5 3.5 0 0 0 10.58 15.20 Z"/></g><circle cx="12" cy="12" r="1.7" fill="currentColor" stroke="none"/></svg></button>
      </nav>
    </div>
  </div>

  <slot />

  <footer class="foot">
    <div class="container">
      <div class="foot-row">
        <a href="/" class="wm" aria-label="Brandon E.B. Ward"><span class="wm-given">Brandon</span> E.B. Ward</a>
        <nav class="foot-nav" aria-label="Footer navigation">
          <a href="/work">Work</a>
          <a href="/writing">Writing</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/colophon">Colophon</a>
        </nav>
        <div class="foot-ext">
          <a href="https://linkedin.com/in/brandonebward" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://github.com/uxward" target="_blank" rel="noopener">GitHub</a>
          <a href="mailto:brandon@uxward.com">Email</a>
        </div>
      </div>
      <div class="colophon-line">
        <span>— Set in Archivo · Built with Astro —</span>
        <span class="fleuron" aria-hidden="true">❦</span>
      </div>
    </div>
  </footer>

  <script>
    (function () {
      var root = document.documentElement;
      var toggles = document.querySelectorAll('.toggle');

      function syncGlyph() {
        var dark = root.getAttribute('data-theme') === 'dark';
        var cyber = root.classList.contains('cyber');
        toggles.forEach(function (t) {
          t.setAttribute('aria-label',
            cyber ? 'Exit cyber mode (back to dark)'
                  : (dark ? 'Switch to light mode' : 'Switch to dark mode'));
        });
      }

      syncGlyph();

      toggles.forEach(function (t) {
        t.addEventListener('click', function () {
          // In cyber the glyph is a radioactive trefoil — clicking it exits
          // Night City straight back to dark mode.
          if (root.classList.contains('cyber')) {
            exitCyber();
            root.setAttribute('data-theme', 'dark');
            try { localStorage.setItem('uxward-theme', 'dark'); } catch (e) {}
            syncGlyph();
            return;
          }
          var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          root.setAttribute('data-theme', next);
          try { localStorage.setItem('uxward-theme', next); } catch (e) {}
          syncGlyph();
        });
      });

      var menuToggle = document.getElementById('menu-toggle');
      var menuClose = document.getElementById('menu-close');
      var overlay = document.getElementById('nav-overlay');

      function openMenu() {
        overlay.classList.add('is-open');
        overlay.setAttribute('aria-hidden', 'false');
        menuToggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        menuToggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      if (menuToggle) menuToggle.addEventListener('click', openMenu);
      if (menuClose) menuClose.addEventListener('click', closeMenu);

      if (overlay) {
        overlay.querySelectorAll('.nav-overlay-menu a').forEach(function (link) {
          link.addEventListener('click', closeMenu);
        });
      }

      /* ════════════════════════════════════════════════
         Cyberpunk easter egg. Type a secret code to flip the whole
         site into wet-neon "Night City" mode. Persists across pages;
         exit via the theme toggle, Esc, or re-typing any code.
         ════════════════════════════════════════════════ */
      var CODES = [
        { keys: ['i', 'd', 'd', 'q', 'd'], label: 'IDDQD // GOD MODE' },
        { keys: ['arrowup', 'arrowup', 'arrowdown', 'arrowdown', 'arrowleft', 'arrowright', 'arrowleft', 'arrowright', 'b', 'a'], label: '↑↑↓↓←→←→BA // KONAMI' },
        { keys: ['c', 'h', 'o', 'n', 'k'], label: 'CHONK' },
        { keys: ['b', 'r', 'a', 'w', 'n', 'd', 'o'], label: "BRAWNDO // IT'S GOT ELECTROLYTES" },
        { keys: ['w', 'h', 'o', 'a', 'h'], label: 'WHOAH' }
      ];
      var MAXLEN = CODES.reduce(function (n, c) { return Math.max(n, c.keys.length); }, 0);
      var buffer = [];
      var transitioning = false;   // guards against re-triggering mid-cinematic

      function showToast(text) {
        var prev = document.querySelector('.cyber-toast');
        if (prev) prev.remove();
        var el = document.createElement('div');
        el.className = 'cyber-toast';
        el.textContent = text;
        document.body.appendChild(el);
        setTimeout(function () {
          el.classList.add('is-leaving');
          setTimeout(function () { el.remove(); }, 320);
        }, 2400);
      }

      // Builds the full-screen FX overlay (static, color flashes, tear bars,
      // a signal message, and the opaque hand-off cover). CSS does the rest.
      function buildFx(label) {
        function box(cls) { var d = document.createElement('div'); d.className = cls; return d; }
        var fx = box('cyber-fx');
        fx.appendChild(box('fx-noise'));
        fx.appendChild(box('fx-flash'));
        for (var b = 0; b < 5; b++) {
          var bar = box('fx-bar');
          bar.style.top = (Math.random() * 88) + '%';
          bar.style.height = (2 + Math.random() * 7) + '%';
          bar.style.animationDuration = (0.25 + Math.random() * 0.5).toFixed(2) + 's';
          bar.style.animationDelay = (Math.random() * 0.5).toFixed(2) + 's';
          fx.appendChild(bar);
        }
        var msg = box('fx-msg');
        msg.textContent = label || '// NIGHT CITY';
        fx.appendChild(msg);
        fx.appendChild(box('fx-cover'));   // opaque cover, last so it paints on top
        return fx;
      }

      // Tag the visible page elements so they fall / fly off as the signal corrupts.
      function tearDownText() {
        var nodes = [].slice.call(document.querySelectorAll(
          'h1,h2,h3,h4,h5,p,li,figure,img,blockquote,figcaption,.marker,.eyebrow,.deck,.cap'
        ));
        var vh = window.innerHeight, picked = [];
        for (var i = 0; i < nodes.length && picked.length < 150; i++) {
          var r = nodes[i].getBoundingClientRect();
          if (r.width <= 0 || r.height <= 0) continue;
          if (r.bottom < -60 || r.top > vh * 1.4) continue;   // skip far off-screen
          picked.push(nodes[i]);
        }
        for (var s = picked.length - 1; s > 0; s--) {          // shuffle for organic stagger
          var j = Math.floor(Math.random() * (s + 1)), t = picked[s];
          picked[s] = picked[j]; picked[j] = t;
        }
        picked.forEach(function (el) {
          var fly = Math.random() < 0.45;
          el.style.setProperty('--tx', ((Math.random() * 2 - 1) * (fly ? 90 : 40)).toFixed(1) + 'vw');
          el.style.setProperty('--ty', (fly ? (-60 - Math.random() * 60) : (90 + Math.random() * 70)).toFixed(1) + 'vh');
          el.style.setProperty('--rot', ((Math.random() * 2 - 1) * (fly ? 180 : 70)).toFixed(0) + 'deg');
          el.style.setProperty('--gd', (0.7 + Math.random() * 0.9).toFixed(2) + 's');
          el.style.animationDelay = (0.5 + Math.random() * 1.8).toFixed(2) + 's';
          el.classList.add(fly ? 'cyber-fly' : 'cyber-fall');
        });
      }

      function goHome() {
        try { history.scrollRestoration = 'manual'; } catch (e) {}
        if (location.pathname === '/') location.reload();
        else location.assign('/');
      }

      // ENTER: ~4s of escalating corruption on the current page, then a covered
      // hand-off to the home page (which powers on out of black). The cyber flag
      // is committed up front so home loads already in Night City.
      function enterCyber(label) {
        if (transitioning) return;
        transitioning = true;
        try { localStorage.setItem('uxward-cyber', '1'); } catch (e) {}
        try { sessionStorage.setItem('uxward-cyber-arriving', label || '// NIGHT CITY'); } catch (e) {}

        if (matchMedia('(prefers-reduced-motion: reduce)').matches) { goHome(); return; }

        root.classList.add('cyber-glitching');
        document.body.appendChild(buildFx(label));
        tearDownText();
        setTimeout(function () { root.classList.add('cyber-peak'); }, 2400);
        setTimeout(function () { root.classList.add('cyber-cover'); }, 3500);
        setTimeout(goHome, 4150);
      }

      function exitCyber() {
        root.classList.remove('cyber');
        try { localStorage.removeItem('uxward-cyber'); } catch (e) {}
        var t = document.querySelector('.cyber-toast');
        if (t) t.remove();
        syncGlyph();
      }

      // Arriving on the home page mid-transition: power on out of the black
      // cover (added at first paint by the before-paint script), land at top.
      (function () {
        var arriving;
        try { arriving = sessionStorage.getItem('uxward-cyber-arriving'); } catch (e) { arriving = null; }
        if (!arriving) return;
        try { sessionStorage.removeItem('uxward-cyber-arriving'); } catch (e) {}
        try { history.scrollRestoration = 'manual'; } catch (e) {}
        root.classList.add('cyber');           // ensure cyber even if before-paint missed it
        syncGlyph();
        window.scrollTo(0, 0);
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            root.classList.add('cyber-arrive-go');
            showToast(arriving);
            setTimeout(function () {
              root.classList.remove('cyber-arriving', 'cyber-arrive-go');
              window.scrollTo(0, 0);
            }, 1000);
          });
        });
      })();

      function normKey(e) {
        var k = e.key;
        if (!k) return null;
        if (k.length === 1) return k.toLowerCase();
        if (k.indexOf('Arrow') === 0) return k.toLowerCase();
        return null;
      }

      document.addEventListener('keydown', function (e) {
        // Don't hijack typing in fields, or modified keystrokes.
        var tag = (e.target && e.target.tagName) || '';
        if (tag === 'INPUT' || tag === 'TEXTAREA' || (e.target && e.target.isContentEditable)) return;
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        if (transitioning) return;   // ignore input while the enter cinematic runs

        if (e.key === 'Escape' && root.classList.contains('cyber')) { exitCyber(); return; }

        var k = normKey(e);
        if (!k) return;
        buffer.push(k);
        if (buffer.length > MAXLEN) buffer.shift();

        for (var i = 0; i < CODES.length; i++) {
          var keys = CODES[i].keys;
          if (buffer.length < keys.length) continue;
          var match = true;
          for (var j = 1; j <= keys.length; j++) {
            if (buffer[buffer.length - j] !== keys[keys.length - j]) { match = false; break; }
          }
          if (match) {
            buffer = [];
            if (root.classList.contains('cyber')) exitCyber();
            else enterCyber(CODES[i].label);
            break;
          }
        }
      });
    })();
  </script>
</body>
</html>
