{
  "name": "uxward-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:preview": "astro build --config astro.config.preview.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "wireframes:png": "for f in D-UX-Design/wireframes/*.excalidraw; do excalidraw-brute-export-cli -i \"$f\" -o \"${f%.excalidraw}.png\" -f png -b true -s 2; done"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "astro": "^6.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.160.1"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.3"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "vite": "^7.3.5",
    "nanoid": "^5.0.9",
    "js-yaml": "^4.2.0",
    "lodash-es": "^4.18.0",
    "dompurify": "^3.4.11"
  }
}
